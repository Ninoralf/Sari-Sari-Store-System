<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %> | <%= store.store_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body data-theme="<%= appearance.theme %>" data-color-scheme="<%= appearance.colorScheme %>" data-font-size="<%= appearance.fontSize %>" data-scale="<%= appearance.scale %>" data-appearance-key="sari-sari-appearance:<%= user ? user.id : 'guest' %>">
<script>
  (() => {
    const allowedThemes = new Set(["Light Mode", "Dark Mode"]);
    const allowedSchemes = new Set(["Emerald", "Blue", "Amber", "Violet", "Ocean", "Rose"]);
    const allowedFontSizes = new Set(["Small", "Normal", "Large", "Extra Large"]);
    const normalizeScale = (value) => {
      const numeric = Number.parseInt(String(value || "").replace("%", ""), 10);
      if (!Number.isFinite(numeric)) return "100";
      return String(Math.min(200, Math.max(10, Math.round(numeric / 10) * 10)));
    };
    try {
      const key = document.body.dataset.appearanceKey;
      const saved = key ? JSON.parse(window.localStorage.getItem(key) || "null") : null;
      if (!saved || typeof saved !== "object") return;
      document.body.dataset.theme = allowedThemes.has(saved.theme) ? saved.theme : "Light Mode";
      document.body.dataset.colorScheme = allowedSchemes.has(saved.colorScheme) ? saved.colorScheme : "Emerald";
      document.body.dataset.fontSize = allowedFontSizes.has(saved.fontSize) ? saved.fontSize : "Normal";
      document.body.dataset.scale = normalizeScale(saved.scale);
    } catch (error) {
      console.warn("Unable to apply browser appearance settings.", error);
    }
  })();
</script>
<% if (user) { %>
  <div class="modal fade whats-new-modal" id="whatsNewModal" tabindex="-1" aria-labelledby="whatsNewModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content border-0">
        <div class="modal-header">
          <div>
            <div class="mini-note text-uppercase fw-bold">What's New</div>
            <h2 class="modal-title h4 mb-0" id="whatsNewModalTitle">Version <span id="whatsNewVersionLabel"></span></h2>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <ul class="whats-new-list mb-0" id="whatsNewChangesList"></ul>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-success px-4" data-bs-dismiss="modal">OK</button>
        </div>
      </div>
    </div>
  </div>
  <script>
    (() => {
      const lastSeenVersionKey = "lastSeenVersion";

      function normalizeVersionPayload(payload) {
        if (!payload || typeof payload !== "object") return null;
        const version = typeof payload.version === "string" ? payload.version.trim() : "";
        if (!version) return null;
        const changes = Array.isArray(payload.changes)
          ? payload.changes.filter((change) => typeof change === "string" && change.trim()).map((change) => change.trim())
          : [];
        return { version, changes };
      }

      function renderWhatsNewModal(release) {
        const versionLabel = document.getElementById("whatsNewVersionLabel");
        const changesList = document.getElementById("whatsNewChangesList");
        const modalElement = document.getElementById("whatsNewModal");
        if (!versionLabel || !changesList || !modalElement) return;

        versionLabel.textContent = release.version;
        changesList.innerHTML = "";

        const changes = release.changes.length ? release.changes : ["This release includes maintenance updates and improvements."];
        changes.forEach((change) => {
          const item = document.createElement("li");
          item.textContent = change;
          changesList.appendChild(item);
        });

        if (window.bootstrap && window.bootstrap.Modal) {
          window.bootstrap.Modal.getOrCreateInstance(modalElement).show();
          return;
        }

        modalElement.classList.add("show");
        modalElement.style.display = "block";
        modalElement.removeAttribute("aria-hidden");
      }

      async function checkForVersionUpdate() {
        try {
          const response = await fetch("/version.json", {
            headers: { Accept: "application/json" },
            cache: "no-store"
          });
          if (!response.ok) return;

          const release = normalizeVersionPayload(await response.json());
          if (!release) return;

          const lastSeenVersion = window.localStorage.getItem(lastSeenVersionKey);
          if (lastSeenVersion === release.version) return;

          renderWhatsNewModal(release);
          window.localStorage.setItem(lastSeenVersionKey, release.version);
        } catch (error) {
          console.warn("Unable to check release notes.", error);
        }
      }

      // On every signed-in page load, this fetches /version.json and compares
      // its version with localStorage.lastSeenVersion. A new version opens the
      // What's New modal once, then saves that version so unchanged releases
      // stay quiet.
      window.addEventListener("load", checkForVersionUpdate);

      // To publish a new update, edit public/version.json, increase "version",
      // and replace the "changes" array with the release notes to show users.
      // To modify release notes without showing the modal again, edit only
      // "changes"; to show the modal again, also change "version".
    })();
  </script>
<% } %>
