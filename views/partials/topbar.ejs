<header class="header-card px-3 px-lg-4 py-3">
  <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3 topbar-brand-group">
      <button class="btn btn-outline-secondary header-menu-button d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar" aria-label="Open navigation menu">
        <i class="bi bi-list fs-4"></i>
      </button>
      <div class="d-none d-lg-flex align-items-center gap-3">
        <div class="brand-chip"><i class="bi bi-shop fs-4"></i></div>
        <div>
          <h1 class="h5 mb-0"><%= store.store_name %></h1>
          <div class="mini-note">Management System</div>
          <div class="mini-note sidebar-date-label mt-1"><%= todayLabel %></div>
        </div>
      </div>
    </div>
    <nav class="nav nav-pills d-none d-lg-flex flex-wrap justify-content-center gap-2 topbar-tabs">
      <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/"><i class="bi bi-grid"></i>Dashboard</a>
      <a class="nav-link <%= currentPath.startsWith('/inventory') ? 'active' : '' %>" href="/inventory"><i class="bi bi-box-seam"></i>Inventory</a>
      <a class="nav-link <%= currentPath.startsWith('/eload') ? 'active' : '' %>" href="/eload"><i class="bi bi-phone"></i>Eload</a>
      <a class="nav-link <%= currentPath.startsWith('/sales') ? 'active' : '' %>" href="/sales"><i class="bi bi-cart3"></i>Sales</a>
      <% if (user && user.role === "Admin") { %>
        <a class="nav-link <%= currentPath.startsWith('/logs') ? 'active' : '' %>" href="/logs"><i class="bi bi-journal-text"></i>Logs</a>
        <a class="nav-link <%= currentPath.startsWith('/reports') ? 'active' : '' %>" href="/reports"><i class="bi bi-bar-chart-line"></i>Reports</a>
        <a class="nav-link <%= currentPath.startsWith('/users') ? 'active' : '' %>" href="/users"><i class="bi bi-people"></i>User Accounts</a>
      <% } %>
    </nav>
    <div class="d-flex flex-wrap align-items-center gap-3">
      <div class="d-flex align-items-center gap-3">
        <div class="dropdown notification-dropdown">
          <button class="btn notification-button position-relative text-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open notifications">
            <i class="bi bi-bell fs-5"></i>
            <% if (notifications.length) { %>
              <span class="notification-count position-absolute top-0 start-100 translate-middle"><%= notifications.length %></span>
            <% } %>
          </button>
          <div class="dropdown-menu dropdown-menu-end notification-menu p-0 overflow-hidden">
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
              <div>
                <div class="fw-semibold">Notifications</div>
                <div class="mini-note"><%= notifications.length ? `${notifications.length} active alert${notifications.length === 1 ? "" : "s"}` : "You're all caught up." %></div>
              </div>
              <a class="btn btn-sm btn-outline-secondary" href="/settings">Settings</a>
            </div>
            <% if (notifications.length) { %>
              <div class="list-group list-group-flush">
                <% notifications.forEach((notification) => { %>
                  <% if (notification.link) { %>
                    <a class="list-group-item border-0 px-3 py-3 notification-item notification-link" href="<%= notification.link %>">
                      <div class="d-flex gap-3">
                        <div class="notification-icon text-<%= notification.tone %>">
                          <i class="bi <%= notification.icon %>"></i>
                        </div>
                        <div>
                          <div class="fw-semibold"><%= notification.title %></div>
                          <div class="mini-note"><%= notification.message %></div>
                        </div>
                      </div>
                    </a>
                  <% } else { %>
                    <div class="list-group-item border-0 px-3 py-3 notification-item">
                      <div class="d-flex gap-3">
                        <div class="notification-icon text-<%= notification.tone %>">
                          <i class="bi <%= notification.icon %>"></i>
                        </div>
                        <div>
                          <div class="fw-semibold"><%= notification.title %></div>
                          <div class="mini-note"><%= notification.message %></div>
                        </div>
                      </div>
                    </div>
                  <% } %>
                <% }) %>
              </div>
            <% } else { %>
              <div class="px-3 py-4 text-center mini-note">No notifications to show.</div>
            <% } %>
          </div>
        </div>
        <% if (user) { %>
          <div class="dropdown">
            <button class="btn account-menu-trigger dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="icon-chip rounded-circle account-menu-avatar"><i class="bi bi-person"></i></span>
              <span class="text-start">
                <span class="d-block fw-semibold"><%= user.full_name %></span>
                <span class="mini-note account-menu-role"><%= user.role %></span>
              </span>
            </button>
            <div class="dropdown-menu dropdown-menu-end account-menu">
              <a class="dropdown-item d-flex align-items-center gap-2" href="/settings">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
              </a>
              <form method="post" action="/logout" class="m-0">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="dropdown-item d-flex align-items-center gap-2" type="submit">
                  <i class="bi bi-box-arrow-right"></i>
                  <span>Logout</span>
                </button>
              </form>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</header>
<button class="btn btn-success pos-cart-fab" type="button" id="globalCartToggleButton" aria-label="Open current cart">
  <i class="bi bi-cart3"></i>
  <span class="pos-cart-fab-count d-none" id="globalCartFabCount">0</span>
</button>
<script>
  window.addEventListener("load", () => {
    document.querySelectorAll(".notification-dropdown").forEach((dropdownElement) => {
      const toggle = dropdownElement.querySelector("[data-bs-toggle='dropdown']");
      if (!toggle || typeof bootstrap === "undefined") return;

      const dropdown = bootstrap.Dropdown.getOrCreateInstance(toggle);
      let hideTimer;

      dropdownElement.addEventListener("mouseenter", () => {
        window.clearTimeout(hideTimer);
        dropdown.show();
      });

      dropdownElement.addEventListener("mouseleave", () => {
        hideTimer = window.setTimeout(() => dropdown.hide(), 140);
      });
    });

    const globalCartToggleButton = document.getElementById("globalCartToggleButton");
    const globalCartFabCount = document.getElementById("globalCartFabCount");
    const salesCartStorageKey = "sales-cart-state";
    const salesCartOpenStorageKey = "sales-cart-open-on-load";
    const currentPath = window.location.pathname;

    function readCartCount() {
      try {
        const raw = window.localStorage.getItem(salesCartStorageKey);
        if (!raw) return 0;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return 0;
        return parsed.reduce((total, item) => total + Math.max(0, Number(item.quantity) || 0), 0);
      } catch (error) {
        return 0;
      }
    }

    function syncCartBadge() {
      const cartCount = readCartCount();
      globalCartFabCount.textContent = String(cartCount);
      globalCartFabCount.classList.toggle("d-none", cartCount <= 0);
      globalCartToggleButton.setAttribute("aria-label", cartCount > 0 ? `Open current cart with ${cartCount} item${cartCount === 1 ? "" : "s"}` : "Open current cart");
    }

    syncCartBadge();
    window.addEventListener("storage", syncCartBadge);
    window.addEventListener("sales-cart-updated", syncCartBadge);

    globalCartToggleButton.addEventListener("click", () => {
      if (currentPath.startsWith("/sales")) {
        window.dispatchEvent(new CustomEvent("sales-cart-toggle-request"));
        return;
      }

      window.localStorage.setItem(salesCartOpenStorageKey, "true");
      window.location.href = "/sales?cart=open";
    });
  });
</script>
