<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="row g-2 g-lg-3 mb-4 dashboard-metrics-grid">
        <div class="col-3 col-md-6 col-xl-4"><a class="content-card dashboard-metric-card p-3 border-start border-4 border-primary h-100 d-block text-reset text-decoration-none" href="/inventory"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-box-seam"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Total Products</div><div class="h2 mb-0 fw-bold dashboard-metric-value" id="dashboardMetricTotalProducts"><%= metrics.totalProducts %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">Current inventory records</div></div></a></div>
        <div class="col-3 col-md-6 col-xl-4"><a class="content-card dashboard-metric-card p-3 border-start border-4 border-warning h-100 d-block text-reset text-decoration-none" href="/inventory?status=Low%20Stock"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-exclamation-triangle"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Low Stock Items</div><div class="h2 mb-0 fw-bold text-warning dashboard-metric-value" id="dashboardMetricLowStock"><%= metrics.lowStockItems %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">Need attention soon</div></div></a></div>
        <div class="col-3 col-md-6 col-xl-4"><a class="content-card dashboard-metric-card p-3 border-start border-4 border-danger h-100 d-block text-reset text-decoration-none" href="/inventory?status=Out%20of%20Stock"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-x-circle"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Out of Stock</div><div class="h2 mb-0 fw-bold text-danger dashboard-metric-value" id="dashboardMetricOutOfStock"><%= metrics.outOfStockItems %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">Reorder immediately</div></div></a></div>
        <div class="col-3 col-md-6 col-xl-4"><div class="content-card dashboard-metric-card p-3 border-start border-4 border-success h-100"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-graph-up"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Daily Sales</div><div class="h2 mb-0 fw-bold text-success dashboard-metric-value" id="dashboardMetricDailySales"><%= formatCurrency(metrics.dailySales) %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">As of <%= currentDateLabel %></div></div></div></div>
        <div class="col-3 col-md-6 col-xl-4"><div class="content-card dashboard-metric-card p-3 border-start border-4 border-info h-100"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-cash-stack"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Total Revenue</div><div class="h2 mb-0 fw-bold dashboard-metric-value" id="dashboardMetricTotalRevenue"><%= formatCurrency(metrics.totalRevenue) %></div><div class="mini-note text-muted dashboard-metric-note">Accumulated sales history</div></div></div></div>
        <div class="col-3 col-md-6 col-xl-4"><div class="content-card dashboard-metric-card p-3 border-start border-4 border-primary h-100"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-cart-check"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Monthly Product Sales</div><div class="h2 mb-0 fw-bold text-warning dashboard-metric-value" id="dashboardMetricMonthlyProducts"><%= formatCurrency(metrics.monthlyProducts) %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">Rolling 30-day inventory sales</div></div></div></div>
        <div class="col-3 col-md-6 col-xl-4"><div class="content-card dashboard-metric-card p-3 border-start border-4 border-success h-100"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-phone"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Monthly eLoad Sales</div><div class="h2 mb-0 fw-bold text-success dashboard-metric-value" id="dashboardMetricMonthlyLoad"><%= formatCurrency(metrics.monthlyLoad) %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">Rolling 30-day load volume</div></div></div></div>
        <div class="col-3 col-md-6 col-xl-4"><div class="content-card dashboard-metric-card p-3 border-start border-4 border-primary h-100"><div class="dashboard-metric-body"><div class="dashboard-metric-icon d-lg-none"><i class="bi bi-wallet2"></i></div><div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Monthly GCash Sales</div><div class="h2 mb-0 fw-bold text-primary dashboard-metric-value" id="dashboardMetricMonthlyGcash"><%= formatCurrency(metrics.monthlyGcash) %></div><div class="mini-note text-muted dashboard-metric-note d-none d-lg-block">Rolling 30-day GCash volume</div></div></div></div>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title" id="dashboardChartTitle"><%= chartTitle %></div>
              </div>
            </div>
            <div class="h-100">
              <canvas id="salesTrendChart" height="110"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- ANALYTICS SECTION -->
      <div class="row g-4 mb-4">
        <div class="col-12">
          <hr class="my-4 opacity-25">
          <div class="section-title h4 mb-4"><i class="bi bi-graph-up-arrow me-2"></i>Analytics & Long-term Insights</div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3">Weekly Sales Performance</div>
            <canvas id="weeklyChart" height="180"></canvas>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3">Monthly Sales Trend</div>
            <canvas id="monthlyChart" height="180"></canvas>
          </div>
        </div>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3">Sales by Category</div>
            <canvas id="categoryPie" height="220"></canvas>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3">Category Revenue Breakdown</div>
            <div class="vstack gap-4" id="categoryBreakdownList">
              <% const totalBreakdown = categoryBreakdown.reduce((sum, item) => sum + item.revenue, 0); %>
              <% categoryBreakdown.forEach((item, index) => { %>
                <% const percentage = totalBreakdown ? ((item.revenue / totalBreakdown) * 100).toFixed(1) : 0; %>
                <div>
                  <div class="d-flex justify-content-between"><div class="fw-semibold"><%= item.category %></div><div><%= formatCurrency(item.revenue) %></div></div>
                  <div class="progress progress-soft mt-2"><div class="progress-bar" role="progressbar" style="width: <%= percentage %>%; background-color: <%= ['#10b981', '#0d9488', '#06b6d4', '#3b82f6', '#6366f1', '#8b5cf6'][index % 6] %>"></div></div>
                  <div class="mini-note mt-1"><%= percentage %>% of total sales</div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12">
          <hr class="my-4 opacity-25">
          <div class="section-title h4 mb-4"><i class="bi bi-activity me-2"></i>Real-time Operations</div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3"><i class="bi bi-trophy text-warning me-2"></i>Best Selling Item This Month</div>
            <% if (bestSellingItem) { %>
              <div class="bg-light rounded-3 p-3 d-flex gap-3 align-items-center border-start border-4 border-warning" id="dashboardBestSellingCard">
                <div class="btn btn-sm btn-light rounded-circle shadow-sm"><i class="bi bi-award text-warning"></i></div>
                <div><div class="fw-bold fs-5"><%= bestSellingItem.name %></div><div class="mini-note"><%= bestSellingItem.quantity_sold %> units sold</div><div class="text-success fw-semibold"><%= formatCurrency(bestSellingItem.revenue) %> revenue</div></div>
              </div>
            <% } %>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="section-title mb-3 text-warning"><i class="bi bi-exclamation-triangle me-2"></i>Low Stock Alert</div>
            <div class="vstack gap-3" id="dashboardLowStockList">
              <% lowStockItems.forEach((item) => { %>
                <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-3 p-3 bg-light text-reset text-decoration-none border-start border-4 border-warning" href="/inventory?status=<%= encodeURIComponent(item.status) %>&search=<%= encodeURIComponent(item.name) %>">
                  <div><div class="fw-semibold"><%= item.name %></div><div class="mini-note"><%= item.category %></div></div>
                  <div class="text-end"><div class="fw-bold <%= item.status === 'Out of Stock' ? 'text-danger' : 'text-warning' %>"><%= item.status %></div><div class="mini-note">Manual stock check</div></div>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-4">
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div class="section-title text-success mb-0"><i class="bi bi-phone me-2"></i>Pending Eload Requests</div>
              <a class="btn btn-outline-success btn-sm rounded-pill px-3" href="/eload">Open Eload Queue</a>
            </div>
            <div class="vstack gap-3" id="dashboardPendingEloadList">
              <% if (!pendingEloadRequests.length) { %>
                <div class="mini-note text-center py-4">No pending eload requests right now.</div>
              <% } else { %>
                <% pendingEloadRequests.forEach((request) => { %>
                  <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-3 p-3 bg-light text-reset text-decoration-none border-start border-4 border-success" href="/eload">
                    <div>
                      <div class="fw-semibold"><%= request.request_code %> | <%= request.mobile_number %></div>
                      <div class="mini-note"><%= request.network || "No network" %> | <%= request.load_value || request.load_type || "Pending load selection" %></div>
                    </div>
                    <div class="text-end">
                      <div class="fw-bold text-success"><%= formatCurrency(request.amount) %></div>
                      <div class="mini-note">Requested by <%= request.requested_by_name || "System" %></div>
                    </div>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="content-card p-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div class="section-title text-primary mb-0"><i class="bi bi-wallet2 me-2"></i>Pending GCash Requests</div>
              <a class="btn btn-outline-primary btn-sm rounded-pill px-3" href="/eload">Open GCash Queue</a>
            </div>
            <div class="vstack gap-3" id="dashboardPendingGcashList">
              <% if (!pendingGcashRequests.length) { %>
                <div class="mini-note text-center py-4">No pending GCash requests right now.</div>
              <% } else { %>
                <% pendingGcashRequests.forEach((request) => { %>
                  <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-3 p-3 bg-light text-reset text-decoration-none border-start border-4 border-primary" href="/eload">
                    <div>
                      <div class="fw-semibold"><%= request.request_code %> | <%= request.mobile_number %></div>
                      <div class="mini-note"><%= request.request_kind || "GCash request" %> | <%= request.reference_no || "Reference pending" %></div>
                    </div>
                    <div class="text-end">
                      <div class="fw-bold text-primary"><%= formatCurrency(request.amount) %></div>
                      <div class="mini-note">Requested by <%= request.requested_by_name || "System" %></div>
                    </div>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>
    <%- include("partials/footer") %>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const chartTitleElement = document.getElementById("dashboardChartTitle");
  const dashboardMetricTotalProducts = document.getElementById("dashboardMetricTotalProducts");
  const dashboardMetricLowStock = document.getElementById("dashboardMetricLowStock");
  const dashboardMetricOutOfStock = document.getElementById("dashboardMetricOutOfStock");
  const dashboardMetricDailySales = document.getElementById("dashboardMetricDailySales");
  const dashboardMetricTotalRevenue = document.getElementById("dashboardMetricTotalRevenue");
  const dashboardMetricMonthlyProducts = document.getElementById("dashboardMetricMonthlyProducts");
  const dashboardMetricMonthlyLoad = document.getElementById("dashboardMetricMonthlyLoad");
  const dashboardMetricMonthlyGcash = document.getElementById("dashboardMetricMonthlyGcash");
  const dashboardBestSellingCard = document.getElementById("dashboardBestSellingCard");
  const dashboardLowStockList = document.getElementById("dashboardLowStockList");
  const dashboardPendingEloadList = document.getElementById("dashboardPendingEloadList");
  const dashboardPendingGcashList = document.getElementById("dashboardPendingGcashList");
  const categoryBreakdownList = document.getElementById("categoryBreakdownList");
  
  const rootStyles = getComputedStyle(document.body);
  const lineColor = rootStyles.getPropertyValue("--line-soft").trim();
  const textColor = rootStyles.getPropertyValue("--text-muted").trim();
  const gcashBlue = rootStyles.getPropertyValue("--brand-blue").trim() || "#3b82f6";
  const loadLightGreen = "#86efac";
  const productsOrange = "#f59e0b";
  const chartColors = ["#10b981", "#0d9488", "#06b6d4", "#3b82f6", "#6366f1", "#8b5cf6"];
  
  let dashboardOverviewRefreshInFlight = false;
  let dashboardChartRefreshInFlight = false;

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function formatPeso(value) {
    return new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(value || 0);
  }

  const sharedOptions = {
    responsive: true,
    plugins: {
      legend: {
        display: true,
        position: "top",
        labels: { color: textColor, usePointStyle: true, boxWidth: 10 }
      }
    },
    scales: {
      x: { ticks: { color: textColor }, grid: { color: lineColor } },
      y: { ticks: { color: textColor }, grid: { color: lineColor } }
    }
  };

  const salesTrendChart = new Chart(document.getElementById("salesTrendChart"), {
    type: "line",
    data: {
      labels: <%- JSON.stringify(chartLabels) %>,
      datasets: [
        { label: "GCash", data: <%- JSON.stringify(chartDatasets[0].values) %>, borderColor: gcashBlue, backgroundColor: gcashBlue, pointBackgroundColor: gcashBlue, fill: false, tension: 0.35 },
        { label: "Load", data: <%- JSON.stringify(chartDatasets[1].values) %>, borderColor: loadLightGreen, backgroundColor: loadLightGreen, pointBackgroundColor: loadLightGreen, fill: false, tension: 0.35 },
        { label: "Products", data: <%- JSON.stringify(chartDatasets[2].values) %>, borderColor: productsOrange, backgroundColor: productsOrange, pointBackgroundColor: productsOrange, fill: false, tension: 0.35 }
      ]
    },
    options: sharedOptions
  });

  const weeklyChart = new Chart(document.getElementById("weeklyChart"), { 
    type: "bar", 
    data: { 
      labels: <%- JSON.stringify(weeklySeries.map(x => x.label)) %>, 
      datasets: [{ data: <%- JSON.stringify(weeklySeries.map(x => x.total)) %>, backgroundColor: "#10b981", borderRadius: 10 }] 
    }, 
    options: { plugins: { legend: { display: false } }, ...sharedOptions } 
  });

  const monthlyChart = new Chart(document.getElementById("monthlyChart"), { 
    type: "line", 
    data: { 
      labels: <%- JSON.stringify(monthlySeries.map(x => x.label)) %>, 
      datasets: [{ data: <%- JSON.stringify(monthlySeries.map(x => x.total)) %>, borderColor: "#0d9488", pointBackgroundColor: "#0d9488", tension: 0.35 }] 
    }, 
    options: { plugins: { legend: { display: false } }, ...sharedOptions } 
  });

  const categoryPie = new Chart(document.getElementById("categoryPie"), { 
    type: "pie", 
    data: { 
      labels: <%- JSON.stringify(categoryBreakdown.map(x => x.category)) %>, 
      datasets: [{ data: <%- JSON.stringify(categoryBreakdown.map(x => x.revenue)) %>, backgroundColor: chartColors }] 
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { color: textColor } } } }
  });

  async function loadDashboardOverview() {
    if (dashboardOverviewRefreshInFlight || document.visibilityState !== "visible") return;
    dashboardOverviewRefreshInFlight = true;
    try {
      const response = await fetch("/api/dashboard/overview", {
        headers: { Accept: "application/json" },
        cache: "no-store"
      });
      if (!response.ok) throw new Error("Failed to load dashboard overview.");
      const payload = await response.json();
      dashboardMetricTotalProducts.textContent = String(payload.metrics.totalProducts);
      dashboardMetricLowStock.textContent = String(payload.metrics.lowStockItems);
      dashboardMetricOutOfStock.textContent = String(payload.metrics.outOfStockItems);
      dashboardMetricDailySales.textContent = formatPeso(payload.metrics.dailySales);
      dashboardMetricTotalRevenue.textContent = formatPeso(payload.metrics.totalRevenue);
      dashboardMetricMonthlyProducts.textContent = formatPeso(payload.metrics.monthlyProducts);
      dashboardMetricMonthlyLoad.textContent = formatPeso(payload.metrics.monthlyLoad);
      dashboardMetricMonthlyGcash.textContent = formatPeso(payload.metrics.monthlyGcash);

      if (payload.bestSellingItem && dashboardBestSellingCard) {
        dashboardBestSellingCard.innerHTML = `
          <div class="btn btn-sm btn-light rounded-circle shadow-sm"><i class="bi bi-award text-warning"></i></div>
          <div><div class="fw-bold fs-5">${payload.bestSellingItem.name}</div><div class="mini-note">${payload.bestSellingItem.quantity_sold} units sold</div><div class="text-success fw-semibold">${new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(payload.bestSellingItem.revenue)} revenue</div></div>
        `;
      }

      if (dashboardLowStockList) {
        dashboardLowStockList.innerHTML = payload.lowStockItems.map((item) => `
          <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-3 p-3 bg-light text-reset text-decoration-none border-start border-4 border-warning" href="/inventory?status=${encodeURIComponent(item.status)}&search=${encodeURIComponent(item.name)}">
            <div><div class="fw-semibold">${item.name}</div><div class="mini-note">${item.category}</div></div>
            <div class="text-end"><div class="fw-bold ${item.status === "Out of Stock" ? "text-danger" : "text-warning"}">${item.status}</div><div class="mini-note">Manual stock check</div></div>
          </a>
        `).join("");
      }

      if (dashboardPendingEloadList) {
        dashboardPendingEloadList.innerHTML = payload.pendingEloadRequests.length
          ? payload.pendingEloadRequests.map((request) => `
            <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-3 p-3 bg-light text-reset text-decoration-none border-start border-4 border-success" href="/eload">
              <div>
                <div class="fw-semibold">${escapeHtml(request.request_code)} | ${escapeHtml(request.mobile_number)}</div>
                <div class="mini-note">${escapeHtml(request.network || "No network")} | ${escapeHtml(request.load_value || request.load_type || "Pending load selection")}</div>
              </div>
              <div class="text-end">
                <div class="fw-bold text-success">${new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(request.amount || 0)}</div>
                <div class="mini-note">Requested by ${escapeHtml(request.requested_by_name || "System")}</div>
              </div>
            </a>
          `).join("")
          : `<div class="mini-note text-center py-4">No pending eload requests right now.</div>`;
      }

      if (dashboardPendingGcashList) {
        dashboardPendingGcashList.innerHTML = payload.pendingGcashRequests.length
          ? payload.pendingGcashRequests.map((request) => `
            <a class="dashboard-alert-link d-flex justify-content-between align-items-center rounded-3 p-3 bg-light text-reset text-decoration-none border-start border-4 border-primary" href="/eload">
              <div>
                <div class="fw-semibold">${escapeHtml(request.request_code)} | ${escapeHtml(request.mobile_number)}</div>
                <div class="mini-note">${escapeHtml(request.request_kind || "GCash request")} | ${escapeHtml(request.reference_no || "Reference pending")}</div>
              </div>
              <div class="text-end">
                <div class="fw-bold text-primary">${new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(request.amount || 0)}</div>
                <div class="mini-note">Requested by ${escapeHtml(request.requested_by_name || "System")}</div>
              </div>
            </a>
          `).join("")
          : `<div class="mini-note text-center py-4">No pending GCash requests right now.</div>`;
      }
      
      // Update Analytics Charts
      weeklyChart.data.labels = payload.weeklySeries.map(x => x.label);
      weeklyChart.data.datasets[0].data = payload.weeklySeries.map(x => x.total);
      weeklyChart.update();
      
      monthlyChart.data.labels = payload.monthlySeries.map(x => x.label);
      monthlyChart.data.datasets[0].data = payload.monthlySeries.map(x => x.total);
      monthlyChart.update();
      
      categoryPie.data.labels = payload.categoryBreakdown.map(x => x.category);
      categoryPie.data.datasets[0].data = payload.categoryBreakdown.map(x => x.revenue);
      categoryPie.update();
      
      const totalBreakdown = payload.categoryBreakdown.reduce((sum, item) => sum + item.revenue, 0);
      categoryBreakdownList.innerHTML = payload.categoryBreakdown.map((item, index) => {
        const percentage = totalBreakdown ? ((item.revenue / totalBreakdown) * 100).toFixed(1) : 0;
        return `
          <div>
            <div class="d-flex justify-content-between"><div class="fw-semibold">${item.category}</div><div>${formatPeso(item.revenue)}</div></div>
            <div class="progress progress-soft mt-2"><div class="progress-bar" role="progressbar" style="width: ${percentage}%; background-color: ${chartColors[index % 6]}"></div></div>
            <div class="mini-note mt-1">${percentage}% of total sales</div>
          </div>
        `;
      }).join("");

    } catch (error) {
      console.error(error);
    } finally {
      dashboardOverviewRefreshInFlight = false;
    }
  }

  async function refreshDashboardChart() {
    if (dashboardChartRefreshInFlight || document.visibilityState !== "visible") return;
    dashboardChartRefreshInFlight = true;
    try {
      const response = await fetch("/api/dashboard/chart", {
        headers: { Accept: "application/json" },
        cache: "no-store"
      });
      if (!response.ok) throw new Error("Failed to load chart data.");
      const chart = await response.json();
      chartTitleElement.textContent = chart.title;
      salesTrendChart.data.labels = chart.labels;
      salesTrendChart.data.datasets[0].data = chart.datasets[0].values;
      salesTrendChart.data.datasets[1].data = chart.datasets[1].values;
      salesTrendChart.data.datasets[2].data = chart.datasets[2].values;
      salesTrendChart.update();
    } catch (error) {
      console.error(error);
    } finally {
      dashboardChartRefreshInFlight = false;
    }
  }

  loadDashboardOverview();
  refreshDashboardChart();
