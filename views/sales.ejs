<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4 sales-workspace">
      <%- include("partials/flash") %>
      <div id="salesLiveAlert"></div>
      
      <div class="d-flex flex-column h-100">
        <!-- Search & Filter Bar -->
        <div class="content-card p-3 mb-4">
          <!-- Search Row -->
          <div class="mb-3">
            <div class="input-group search-glass">
              <span class="input-group-text border-0 bg-transparent ps-3"><i class="bi bi-search text-muted"></i></span>
              <input class="form-control border-0 bg-transparent py-2" id="quickItemSearch" placeholder="Search product or category..." autocomplete="off">
            </div>
          </div>
          
          <!-- Category Row (Scrollable) -->
          <div class="d-flex gap-2 category-pill-container flex-nowrap overflow-auto no-scrollbar py-1">
            <button class="btn btn-sm btn-category active flex-shrink-0" data-category="all">All Items</button>
            <% categories.forEach(cat => { %>
              <button class="btn btn-sm btn-category flex-shrink-0" data-category="<%= cat.category_name %>"><%= cat.category_name %></button>
            <% }) %>
          </div>
        </div>

        <!-- Product Grid -->
        <div class="flex-grow-1 overflow-auto pe-2 product-grid-container">
          <div class="row g-3 g-lg-4" id="quickSuggestions">
            <!-- Items rendered via JS -->
          </div>
          
          <div id="emptySearchState" class="d-none text-center py-5">
            <div class="mb-3">
              <i class="bi bi-box-seam display-1 text-muted opacity-25"></i>
            </div>
            <h3 class="h5 fw-bold">No products found</h3>
            <p class="text-secondary">Try a different search term or category.</p>
          </div>
        </div>
      </div>

      <form method="post" action="/sales/add" id="saleForm" class="d-none">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="saleDate" value="<%= saleDateDefault %>">
        <input type="hidden" name="paymentMethod" value="Cash">
        <div id="saleHiddenInputs"></div>
      </form>
    </section>
  </main>
</div>

<div class="pos-cart-backdrop" id="cartBackdrop" hidden></div>
<aside class="content-card pos-cart-flyout" id="cartFlyout" aria-hidden="true">
  <div class="p-3 p-lg-4 pos-cart-content">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
      <div>
        <div class="section-title">Current Cart</div>
        <div class="mini-note">Review the order here while the product list stays open.</div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button class="btn btn-outline-secondary" type="button" id="newCustomerButton">New Customer</button>
        <button class="btn btn-outline-secondary pos-cart-close" type="button" id="closeCartButton" aria-label="Close cart">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    </div>

    <div class="table-responsive pos-cart-table-wrap">
      <table class="table align-middle mb-0 pos-cart-table">
        <thead>
          <tr>
            <th>Item</th>
            <th class="text-end">Price</th>
            <th>Qty</th>
            <th class="text-end">Total</th>
            <th class="text-end"><span class="d-none d-sm-inline">Action</span></th>
          </tr>
        </thead>
        <tbody id="saleCartBody">
          <tr id="emptyCartRow">
            <td colspan="5" class="text-center py-4 mini-note">No items in the cart yet.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="row g-3 mt-1 pos-cart-summary-grid">
      <div class="col-4">
        <div class="content-card p-3 h-100 pos-cart-summary-card">
          <div class="mini-note pos-cart-summary-label">Cart Items</div>
          <div class="h3 mb-0 pos-cart-summary-value" id="cartItemCount">0</div>
        </div>
      </div>
      <div class="col-4">
        <div class="content-card p-3 h-100 pos-cart-summary-card">
          <div class="mini-note pos-cart-summary-label">Total Quantity</div>
          <div class="h3 mb-0 pos-cart-summary-value" id="cartUnitCount">0</div>
        </div>
      </div>
      <div class="col-4">
        <div class="content-card p-3 h-100 pos-cart-summary-card">
          <div class="mini-note pos-cart-summary-label">Grand Total</div>
          <div class="h3 mb-0 text-success pos-cart-summary-value pos-cart-summary-money" id="saleGrandTotal">PHP 0.00</div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3 pos-cart-actions">
      <button class="btn btn-success btn-lg" type="submit" form="saleForm">Complete Sale</button>
    </div>
  </div>
</aside>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const inventoryItems = <%- JSON.stringify(inventory) %>;
  const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" });
  const searchInput = document.getElementById("quickItemSearch");
  const suggestions = document.getElementById("quickSuggestions");
  const emptySearchState = document.getElementById("emptySearchState");
  const categoryButtons = document.querySelectorAll(".btn-category");
  const cartBody = document.getElementById("saleCartBody");
  const hiddenInputs = document.getElementById("saleHiddenInputs");
  const grandTotal = document.getElementById("saleGrandTotal");
  const cartItemCount = document.getElementById("cartItemCount");
  const cartUnitCount = document.getElementById("cartUnitCount");
  const saleForm = document.getElementById("saleForm");
  const newCustomerButton = document.getElementById("newCustomerButton");
  const closeCartButton = document.getElementById("closeCartButton");
  const cartToggleButton = document.getElementById("globalCartToggleButton");
  const cartBackdrop = document.getElementById("cartBackdrop");
  const cartFlyout = document.getElementById("cartFlyout");
  const cartFabCount = document.getElementById("globalCartFabCount");
  const salesLiveAlert = document.getElementById("salesLiveAlert");
  const cartStorageKey = "sales-cart-state";
  const cartOpenStorageKey = "sales-cart-open-on-load";

  let activeCategory = "all";
  let cart = loadStoredCart();
  let isCartOpen = false;

  function loadStoredCart() {
    try {
      const raw = window.localStorage.getItem(cartStorageKey);
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) return [];
      return parsed.map(entry => {
        if (entry?.type === "eload") {
          return entry;
        }
        const item = inventoryItems.find(i => i.id === Number(entry.id));
        if (!item || item.status === "Out of Stock") return null;
        return {
          id: item.id,
          type: "inventory",
          name: item.name,
          price: item.selling_price,
          quantity: Math.max(1, Number(entry.quantity) || 1)
        };
      }).filter(Boolean);
    } catch (e) { return []; }
  }

  function persistCart() {
    window.localStorage.setItem(cartStorageKey, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent("sales-cart-updated"));
  }

  function setCartOpen(open) {
    isCartOpen = Boolean(open);
    cartFlyout.classList.toggle("is-open", isCartOpen);
    cartFlyout.setAttribute("aria-hidden", String(!isCartOpen));
    cartBackdrop.hidden = !isCartOpen;
    if (cartToggleButton) cartToggleButton.setAttribute("aria-expanded", String(isCartOpen));
  }

  function toggleCart() { setCartOpen(!isCartOpen); }

  function escapeHtml(value) {
    return String(value ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  function focusSearch(preventScroll = true) {
    searchInput.focus({ preventScroll });
  }

  function searchItems(query) {
    const normalized = query.trim().toLowerCase();
    return inventoryItems.filter(item => {
      const matchesSearch = !normalized || `${item.name} ${item.category}`.toLowerCase().includes(normalized);
      const matchesCategory = activeCategory === "all" || item.category === activeCategory;
      return matchesSearch && matchesCategory;
    });
  }

  function renderSuggestions() {
    const items = searchItems(searchInput.value);
    
    if (!items.length) {
      suggestions.innerHTML = "";
      emptySearchState.classList.remove("d-none");
      return;
    }

    emptySearchState.classList.add("d-none");
    suggestions.innerHTML = items.map(item => {
      const statusClass = item.status === "Low Stock" ? "text-warning" : "text-success";
      return `
        <div class="col-6 col-sm-4 col-md-3 col-xl-2">
          <div class="product-card h-100" onclick="addItemToCart(${item.id}, 1)">
            <div class="product-card-body">
              <div class="category-tag mb-2">${escapeHtml(item.category)}</div>
              <div class="product-name fw-bold mb-1">${escapeHtml(item.name)}</div>
              <div class="product-price text-success fw-bold">${peso.format(item.selling_price)}</div>
            </div>
            <div class="product-card-footer mt-auto pt-2">
               <div class="d-flex justify-content-between align-items-center">
                 <span class="mini-note fw-bold ${statusClass}">${escapeHtml(item.status)}</span>
                 <i class="bi bi-plus-circle-fill text-success fs-5"></i>
               </div>
            </div>
          </div>
        </div>
      `;
    }).join("");
  }

  function addItemToCart(itemId, quantity) {
    const item = inventoryItems.find(i => i.id === Number(itemId));
    if (!item) return;

    const existing = cart.find(entry => entry.id === item.id && entry.type === "inventory");
    if (existing) {
      existing.quantity += quantity;
    } else {
      cart.push({
        id: item.id,
        type: "inventory",
        name: item.name,
        price: item.selling_price,
        quantity: quantity
      });
    }

    renderCart();
    showSalesAlert("success", `Added ${item.name} to cart.`);
    
    // Pulse animation for cart fab
    const fab = document.getElementById("globalCartToggleButton");
    if (fab) {
      fab.classList.add("pulse-animation");
      setTimeout(() => fab.classList.remove("pulse-animation"), 1000);
    }
  }

  function renderCart() {
    if (!cart.length) {
      cartBody.innerHTML = '<tr id="emptyCartRow"><td colspan="5" class="text-center py-4 mini-note">No items in the cart yet.</td></tr>';
      hiddenInputs.innerHTML = "";
      grandTotal.textContent = peso.format(0);
      cartItemCount.textContent = "0";
      cartUnitCount.textContent = "0";
      if (cartFabCount) cartFabCount.textContent = "0";
      persistCart();
      return;
    }

    let totalAmount = 0;
    let totalUnits = 0;

    cartBody.innerHTML = cart.map((item, index) => {
      const lineTotal = item.quantity * item.price;
      totalAmount += lineTotal;
      totalUnits += item.quantity;
      return `
        <tr>
          <td>
            <div class="fw-semibold">${escapeHtml(item.name)}</div>
            <div class="mini-note">${item.type === "eload" ? `${escapeHtml(item.network)} | ${escapeHtml(item.mobileNumber)}` : "Product"}</div>
          </td>
          <td class="text-end">${peso.format(item.price)}</td>
          <td>
            ${item.type === "eload"
              ? `<div class="form-control form-control-sm bg-light">1 req</div>`
              : `<div class="input-group input-group-sm" style="width: 100px;">
                   <button class="btn btn-outline-secondary cart-qty-step" type="button" data-index="${index}" data-step="-1">-</button>
                   <input class="form-control text-center cart-qty-input" type="number" min="1" value="${item.quantity}" data-index="${index}">
                   <button class="btn btn-outline-secondary cart-qty-step" type="button" data-index="${index}" data-step="1">+</button>
                 </div>`}
          </td>
          <td class="text-end fw-semibold">${peso.format(lineTotal)}</td>
          <td class="text-end">
            <button class="btn btn-sm text-danger remove-cart-item" type="button" data-index="${index}"><i class="bi bi-trash"></i></button>
          </td>
        </tr>
      `;
    }).join("");

    hiddenInputs.innerHTML = cart.map(item => `
      <input type="hidden" name="itemId" value="${item.type === "inventory" ? item.id : ""}">
      <input type="hidden" name="quantity" value="${item.quantity}">
      <input type="hidden" name="price" value="${item.price}">
    `).join("");

    grandTotal.textContent = peso.format(totalAmount);
    cartItemCount.textContent = String(cart.length);
    cartUnitCount.textContent = String(totalUnits);
    if (cartFabCount) cartFabCount.textContent = String(totalUnits);
    persistCart();
  }

  function resetForNewCustomer() {
    cart = [];
    renderCart();
    searchInput.value = "";
    renderSuggestions();
    focusSearch(true);
  }

  function showSalesAlert(type, message) {
    salesLiveAlert.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show app-flash-popup" role="alert">${escapeHtml(message)}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
    setTimeout(() => {
      const alert = salesLiveAlert.querySelector(".alert");
      if (alert) bootstrap.Alert.getOrCreateInstance(alert).close();
    }, 3000);
  }

  // Event Listeners
  searchInput.addEventListener("input", renderSuggestions);

  categoryButtons.forEach(btn => {
    btn.addEventListener("click", () => {
      categoryButtons.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      activeCategory = btn.dataset.category;
      renderSuggestions();
    });
  });

  cartBody.addEventListener("click", (e) => {
    const stepBtn = e.target.closest(".cart-qty-step");
    if (stepBtn) {
      const idx = Number(stepBtn.dataset.index);
      const step = Number(stepBtn.dataset.step);
      cart[idx].quantity = Math.max(1, cart[idx].quantity + step);
      renderCart();
      return;
    }
    const removeBtn = e.target.closest(".remove-cart-item");
    if (removeBtn) {
      cart.splice(Number(removeBtn.dataset.index), 1);
      renderCart();
    }
  });

  cartBody.addEventListener("change", (e) => {
    if (e.target.classList.contains("cart-qty-input")) {
      const idx = Number(e.target.dataset.index);
      cart[idx].quantity = Math.max(1, Number(e.target.value) || 1);
      renderCart();
    }
  });

  saleForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!cart.length) return;

    const payload = {
      _csrf: document.querySelector('input[name="_csrf"]').value,
      saleDate: document.querySelector('input[name="saleDate"]').value,
      paymentMethod: "Cash",
      items: cart.filter(i => i.type === "inventory").map(i => ({ inventoryItemId: i.id, quantity: i.quantity, price: i.price })),
      digitalItems: cart.filter(i => i.type === "eload").map(i => ({ ...i }))
    };

    try {
      const resp = await fetch("/api/sales", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const data = await resp.json();
      if (!resp.ok) throw new Error(data.error || "Failed to complete sale.");
      showSalesAlert("success", "Sale completed successfully!");
      resetForNewCustomer();
      setCartOpen(false);
    } catch (err) {
      showSalesAlert("danger", err.message);
    }
  });

  newCustomerButton.addEventListener("click", resetForNewCustomer);
  closeCartButton.addEventListener("click", () => setCartOpen(false));
  cartBackdrop.addEventListener("click", () => setCartOpen(false));
  window.addEventListener("sales-cart-toggle-request", toggleCart);

  // Initial render
  renderSuggestions();
  renderCart();
  focusSearch(true);
</script>
</body>
</html>
