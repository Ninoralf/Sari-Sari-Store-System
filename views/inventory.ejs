<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      
      <!-- Inventory Header & Metrics -->
      <div class="row g-2 g-lg-3 mb-4 inventory-summary-grid">
        <div class="col-3 col-md-3">
          <div class="content-card dashboard-metric-card p-3 border-start border-4 border-primary h-100">
            <div class="dashboard-metric-body">
              <div class="dashboard-metric-icon d-lg-none"><i class="bi bi-box-seam"></i></div>
              <div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Total Items</div>
              <div class="h2 mb-0 fw-bold dashboard-metric-value" id="inventorySummaryTotal"><%= summary.total %></div>
            </div>
          </div>
        </div>
        <div class="col-3 col-md-3">
          <div class="content-card dashboard-metric-card p-3 border-start border-4 border-success h-100">
            <div class="dashboard-metric-body">
              <div class="dashboard-metric-icon d-lg-none"><i class="bi bi-check-circle"></i></div>
              <div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">In Stock</div>
              <div class="h2 mb-0 fw-bold text-success dashboard-metric-value" id="inventorySummaryInStock"><%= summary.inStock %></div>
            </div>
          </div>
        </div>
        <div class="col-3 col-md-3">
          <div class="content-card dashboard-metric-card p-3 border-start border-4 border-warning h-100">
            <div class="dashboard-metric-body">
              <div class="dashboard-metric-icon d-lg-none"><i class="bi bi-exclamation-triangle"></i></div>
              <div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Low Stock</div>
              <div class="h2 mb-0 fw-bold text-warning dashboard-metric-value" id="inventorySummaryLowStock"><%= summary.lowStock %></div>
            </div>
          </div>
        </div>
        <div class="col-3 col-md-3">
          <div class="content-card dashboard-metric-card p-3 border-start border-4 border-danger h-100">
            <div class="dashboard-metric-body">
              <div class="dashboard-metric-icon d-lg-none"><i class="bi bi-x-circle"></i></div>
              <div class="mini-note text-uppercase fw-bold dashboard-metric-label d-none d-lg-block">Out of Stock</div>
              <div class="h2 mb-0 fw-bold text-danger dashboard-metric-value" id="inventorySummaryOutOfStock"><%= summary.outOfStock %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="content-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <div class="section-title">Inventory Management</div>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" id="inventoryPrintButton" title="Print">
              <i class="bi bi-printer"></i> <span class="d-none d-lg-inline ms-1">Print</span>
            </button>
            <% if (user && user.role === "Admin") { %>
              <button class="btn btn-outline-primary btn-sm rounded-pill px-2 px-lg-4" data-bs-toggle="modal" data-bs-target="#manageCategoriesModal" title="Categories">
                <i class="bi bi-tags"></i> <span class="d-none d-lg-inline ms-1">Categories</span>
              </button>
              <button class="btn btn-outline-primary btn-sm rounded-pill px-2 px-lg-4" data-bs-toggle="modal" data-bs-target="#manageSuppliersModal" title="Suppliers">
                <i class="bi bi-truck"></i> <span class="d-none d-lg-inline ms-1">Suppliers</span>
              </button>
              <button class="btn btn-success btn-sm rounded-pill px-2 px-lg-4" data-bs-toggle="modal" data-bs-target="#addItemModal" title="Add Item">
                <i class="bi bi-plus-lg"></i> <span class="d-none d-lg-inline ms-1">Add Item</span>
              </button>
            <% } %>
          </div>
        </div>

        <!-- Filters -->
        <div class="row g-2 mb-2" id="inventoryFilterForm">
          <div class="col-md-7">
            <div class="input-group shadow-sm rounded-3 overflow-hidden border">
              <span class="input-group-text border-0 bg-white"><i class="bi bi-search text-muted"></i></span>
              <input class="form-control border-0" id="inventoryLiveSearch" placeholder="Search by barcode, name, category, or supplier...">
            </div>
          </div>
          <div class="col-md-5">
            <select class="form-select border-0 shadow-sm bg-light" id="inventoryStatusFilter">
              <option value="all">All Statuses</option>
              <option value="In Stock">In Stock</option>
              <option value="Low Stock">Low Stock</option>
              <option value="Out of Stock">Out of Stock</option>
            </select>
          </div>
        </div>
        <div class="mini-note d-none mb-4" id="inventoryFilterSummary"></div>

        <div class="table-responsive">
          <table class="table align-middle table-hover">
            <thead class="bg-light">
              <tr>
                <th class="border-0 rounded-start ps-3">Item Details</th>
                <th class="border-0 text-end">Price</th>
                <th class="border-0">Status</th>
                <% if (user && user.role === "Admin") { %>
                  <th class="border-0 text-end rounded-end pe-3">Actions</th>
                <% } else { %>
                  <th class="border-0 rounded-end"></th>
                <% } %>
              </tr>
            </thead>
            <tbody id="inventoryTableBody">
              <% items.forEach((item) => { %>
                <tr class="inventory-row">
                  <td class="ps-3 py-3">
                    <div class="fw-bold text-dark"><%= item.name %></div>
                    <div class="mini-note text-muted"><%= item.category %> | <%= item.supplier || 'No Supplier' %></div>
                    <div class="mini-note text-muted">Barcode: <%= item.barcode %></div>
                  </td>
                  <td class="text-end">
                    <div class="fw-bold text-success"><%= formatCurrency(item.selling_price) %></div>
                    <% if (user && user.role === "Admin") { %>
                      <div class="mini-note text-muted">Cost: <%= formatCurrency(item.unit_price) %></div>
                    <% } %>
                  </td>
                  <td>
                    <% if (item.status === "In Stock") { %>
                      <span class="badge rounded-pill bg-success-subtle text-success px-3">IN STOCK</span>
                    <% } else if (item.status === "Low Stock") { %>
                      <span class="badge rounded-pill bg-warning-subtle text-warning px-3">LOW STOCK</span>
                    <% } else { %>
                      <span class="badge rounded-pill bg-danger-subtle text-danger px-3">OUT OF STOCK</span>
                    <% } %>
                  </td>
                  <td class="text-end pe-3">
                    <% if (user && user.role === "Admin") { %>
                      <div class="d-flex justify-content-end gap-1">
                        <button class="btn btn-sm btn-light rounded-circle" data-bs-toggle="modal" data-bs-target="#editItemModal-<%= item.id %>" title="Edit">
                          <i class="bi bi-pencil text-primary"></i>
                        </button>
                        <form method="post" action="/inventory/<%= item.id %>/delete" onsubmit="return confirm('Delete this item?');" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-light rounded-circle" title="Delete">
                            <i class="bi bi-trash text-danger"></i>
                          </button>
                        </form>
                      </div>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <%- include("partials/footer") %>
  </main>
</div>

<% if (user && user.role === "Admin") { %>
<!-- CATEGORY MANAGEMENT MODAL -->
<div class="modal fade" id="manageCategoriesModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content rounded-4 shadow-lg border-0">
      <div class="modal-header border-0 pb-0">
        <div class="section-title">Manage Categories</div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="mini-note">Manage product categories used in inventory forms and reports.</div>
          <button class="btn btn-success btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
            <i class="bi bi-plus-lg me-1"></i> Add Category
          </button>
        </div>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Category ID</th>
                <th>Category Name</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!categories.length) { %>
                <tr><td colspan="3" class="text-center py-4 mini-note">No categories added yet.</td></tr>
              <% } else { %>
                <% categories.forEach((category) => { %>
                  <tr>
                    <td class="fw-semibold"><%= category.category_id %></td>
                    <td><%= category.category_name %></td>
                    <td class="text-end">
                      <button class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#editCategoryModal-<%= category.category_id %>"><i class="bi bi-pencil"></i></button>
                      <form class="d-inline" method="post" action="/settings/categories/<%= category.category_id %>/delete" onsubmit="return confirm('Delete this category? Categories used by products cannot be deleted.');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- SUPPLIER MANAGEMENT MODAL -->
<div class="modal fade" id="manageSuppliersModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content rounded-4 shadow-lg border-0">
      <div class="modal-header border-0 pb-0">
        <div class="section-title">Manage Suppliers</div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="mini-note">Manage supplier records for inventory references.</div>
          <button class="btn btn-success btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addSupplierModal">
            <i class="bi bi-plus-lg me-1"></i> Add Supplier
          </button>
        </div>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Supplier ID</th>
                <th>Supplier Name</th>
                <th>Contact No</th>
                <th>Address</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!suppliers.length) { %>
                <tr><td colspan="5" class="text-center py-4 mini-note">No suppliers added yet.</td></tr>
              <% } else { %>
                <% suppliers.forEach((supplier) => { %>
                  <tr>
                    <td class="fw-semibold"><%= supplier.supplier_id %></td>
                    <td><%= supplier.supplier_name %></td>
                    <td><%= supplier.contact_no || "-" %></td>
                    <td><%= supplier.address || "-" %></td>
                    <td class="text-end">
                      <button class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#editSupplierModal-<%= supplier.supplier_id %>"><i class="bi bi-pencil"></i></button>
                      <form class="d-inline" method="post" action="/settings/suppliers/<%= supplier.supplier_id %>/delete" onsubmit="return confirm('Delete this supplier?');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD CATEGORY MODAL -->
<div class="modal fade" id="addCategoryModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form method="post" action="/settings/categories/add">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header"><h5 class="modal-title">Add Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <label class="form-label">Category Name</label>
          <input class="form-control" name="categoryName" required>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#manageCategoriesModal">Back</button><button class="btn btn-success">Save Category</button></div>
      </form>
    </div>
  </div>
</div>

<% categories.forEach((category) => { %>
  <!-- EDIT CATEGORY MODAL -->
  <div class="modal fade" id="editCategoryModal-<%= category.category_id %>" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form method="post" action="/settings/categories/<%= category.category_id %>/update">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="modal-header"><h5 class="modal-title">Edit Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
          <div class="modal-body">
            <label class="form-label">Category Name</label>
            <input class="form-control" name="categoryName" value="<%= category.category_name %>" required>
          </div>
          <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#manageCategoriesModal">Back</button><button class="btn btn-success">Update Category</button></div>
        </form>
      </div>
    </div>
  </div>
<% }) %>

<!-- ADD SUPPLIER MODAL -->
<div class="modal fade" id="addSupplierModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <form method="post" action="/settings/suppliers/add">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header"><h5 class="modal-title">Add Supplier</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Supplier Name</label><input class="form-control" name="supplierName" required></div>
            <div class="col-md-6"><label class="form-label">Contact No</label><input class="form-control" name="contactNo"></div>
            <div class="col-12"><label class="form-label">Address</label><textarea class="form-control" name="address" rows="3"></textarea></div>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#manageSuppliersModal">Back</button><button class="btn btn-success">Save Supplier</button></div>
      </form>
    </div>
  </div>
</div>

<% suppliers.forEach((supplier) => { %>
  <!-- EDIT SUPPLIER MODAL -->
  <div class="modal fade" id="editSupplierModal-<%= supplier.supplier_id %>" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <form method="post" action="/settings/suppliers/<%= supplier.supplier_id %>/update">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="modal-header"><h5 class="modal-title">Edit Supplier</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-6"><label class="form-label">Supplier Name</label><input class="form-control" name="supplierName" value="<%= supplier.supplier_name %>" required></div>
              <div class="col-md-6"><label class="form-label">Contact No</label><input class="form-control" name="contactNo" value="<%= supplier.contact_no || '' %>"></div>
              <div class="col-12"><label class="form-label">Address</label><textarea class="form-control" name="address" rows="3"><%= supplier.address || '' %></textarea></div>
            </div>
          </div>
          <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#manageSuppliersModal">Back</button><button class="btn btn-success">Update Supplier</button></div>
        </form>
      </div>
    </div>
  </div>
<% }) %>

<!-- ADD ITEM MODAL (FLOATING PANEL) -->
<div class="modal fade" id="addItemModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 shadow-lg border-0">
      <form action="/inventory/add" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header border-0 pb-0">
          <div class="section-title">Add New Item</div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
          <div class="vstack gap-4">
            <!-- STEP 1 -->
            <div>
              <div class="d-flex align-items-center gap-3 mb-3">
                <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 24px; height: 28px;">1</span>
                <span class="fw-bold text-uppercase small">Basic Information</span>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold">Barcode</label>
                <div class="barcode-scan-actions">
                  <input class="form-control bg-light border-0 py-2 barcode-input" name="barcode" id="addItemBarcode" placeholder="Scan or type barcode" autocomplete="off" required>
                  <button type="button" class="btn btn-outline-primary barcode-scan-btn" data-barcode-target="addItemBarcode">
                    <i class="bi bi-upc-scan me-1"></i>Scan Barcode
                  </button>
                  <button type="button" class="btn btn-outline-secondary barcode-clear-btn" data-barcode-target="addItemBarcode">Clear</button>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold">Item Name</label>
                <input class="form-control bg-light border-0 py-2" name="name" placeholder="e.g. Coca-Cola 1.5L" required>
              </div>
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label small fw-bold">Category</label>
                  <select class="form-select bg-light border-0" name="category" required>
                    <option value="" disabled selected>Select...</option>
                    <% categories.forEach(cat => { %>
                      <option value="<%= cat.category_name %>"><%= cat.category_name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small fw-bold">Supplier</label>
                  <input class="form-control bg-light border-0" name="supplier" list="supplierList" placeholder="e.g. Monde">
                </div>
              </div>
            </div>

            <!-- STEP 2 -->
            <div>
              <div class="d-flex align-items-center gap-3 mb-3">
                <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">2</span>
                <span class="fw-bold text-uppercase small">Pricing & Stock Status</span>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label small fw-bold">Unit Cost (Capital)</label>
                  <div class="input-group input-group-sm">
                    <span class="input-group-text border-0 bg-white">₱</span>
                    <input class="form-control bg-light border-0" type="number" step="0.01" name="unitPrice" placeholder="0.00" required>
                  </div>
                </div>
                <div class="col-6">
                  <label class="form-label small fw-bold">Selling Price</label>
                  <div class="input-group input-group-sm">
                    <span class="input-group-text border-0 bg-white">₱</span>
                    <input class="form-control bg-light border-0" type="number" step="0.01" name="sellingPrice" placeholder="0.00" required>
                  </div>
                </div>
              </div>
              <div>
                <label class="form-label small fw-bold">Current Status</label>
                <div class="d-flex gap-2 p-1 bg-light rounded-pill">
                  <input class="btn-check" type="radio" name="status" id="statusInNew" value="In Stock" checked>
                  <label class="btn btn-white btn-sm flex-grow-1 rounded-pill border-0" for="statusInNew">IN STOCK</label>
                  <input class="btn-check" type="radio" name="status" id="statusLowNew" value="Low Stock">
                  <label class="btn btn-white btn-sm flex-grow-1 rounded-pill border-0" for="statusLowNew">LOW</label>
                  <input class="btn-check" type="radio" name="status" id="statusOutNew" value="Out of Stock">
                  <label class="btn btn-white btn-sm flex-grow-1 rounded-pill border-0" for="statusOutNew">OUT</label>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer border-0 p-4 pt-0">
          <button class="btn btn-success w-100 py-3 fw-bold rounded-3 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>ADD TO INVENTORY
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<% items.forEach((item) => { %>
<!-- EDIT ITEM MODAL -->
<div class="modal fade" id="editItemModal-<%= item.id %>" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 shadow-lg border-0">
      <form action="/inventory/<%= item.id %>/update" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header border-0 pb-0">
          <div class="section-title">Edit Item Details</div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
          <div class="vstack gap-4">
            <!-- STEP 1 -->
            <div>
              <div class="d-flex align-items-center gap-3 mb-3">
                <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 24px; height: 28px;">1</span>
                <span class="fw-bold text-uppercase small">Basic Information</span>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold">Barcode</label>
                <div class="barcode-scan-actions">
                  <input class="form-control bg-light border-0 py-2 barcode-input" name="barcode" id="editItemBarcode-<%= item.id %>" value="<%= item.barcode %>" placeholder="Scan or type barcode" autocomplete="off" required>
                  <button type="button" class="btn btn-outline-primary barcode-scan-btn" data-barcode-target="editItemBarcode-<%= item.id %>">
                    <i class="bi bi-upc-scan me-1"></i>Scan Barcode
                  </button>
                  <button type="button" class="btn btn-outline-secondary barcode-clear-btn" data-barcode-target="editItemBarcode-<%= item.id %>">Clear</button>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold">Item Name</label>
                <input class="form-control bg-light border-0 py-2" name="name" value="<%= item.name %>" required>
              </div>
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label small fw-bold">Category</label>
                  <select class="form-select bg-light border-0" name="category" required>
                    <% categories.forEach(cat => { %>
                      <option value="<%= cat.category_name %>" <%= item.category === cat.category_name ? 'selected' : '' %>><%= cat.category_name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label small fw-bold">Supplier</label>
                  <input class="form-control bg-light border-0" name="supplier" list="supplierList" value="<%= item.supplier || '' %>">
                </div>
              </div>
            </div>

            <!-- STEP 2 -->
            <div>
              <div class="d-flex align-items-center gap-3 mb-3">
                <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">2</span>
                <span class="fw-bold text-uppercase small">Pricing & Stock Status</span>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label small fw-bold">Unit Cost (Capital)</label>
                  <div class="input-group input-group-sm">
                    <span class="input-group-text border-0 bg-white">₱</span>
                    <input class="form-control bg-light border-0" type="number" step="0.01" name="unitPrice" value="<%= item.unit_price %>" required>
                  </div>
                </div>
                <div class="col-6">
                  <label class="form-label small fw-bold">Selling Price</label>
                  <div class="input-group input-group-sm">
                    <span class="input-group-text border-0 bg-white">₱</span>
                    <input class="form-control bg-light border-0" type="number" step="0.01" name="sellingPrice" value="<%= item.selling_price %>" required>
                  </div>
                </div>
              </div>
              <div>
                <label class="form-label small fw-bold">Current Status</label>
                <div class="d-flex gap-2 p-1 bg-light rounded-pill">
                  <input class="btn-check" type="radio" name="status" id="statusIn-<%= item.id %>" value="In Stock" <%= item.status === 'In Stock' ? 'checked' : '' %>>
                  <label class="btn btn-white btn-sm flex-grow-1 rounded-pill border-0" for="statusIn-<%= item.id %>">IN STOCK</label>
                  <input class="btn-check" type="radio" name="status" id="statusLow-<%= item.id %>" value="Low Stock" <%= item.status === 'Low Stock' ? 'checked' : '' %>>
                  <label class="btn btn-white btn-sm flex-grow-1 rounded-pill border-0" for="statusLow-<%= item.id %>">LOW</label>
                  <input class="btn-check" type="radio" name="status" id="statusOut-<%= item.id %>" value="Out of Stock" <%= item.status === 'Out of Stock' ? 'checked' : '' %>>
                  <label class="btn btn-white btn-sm flex-grow-1 rounded-pill border-0" for="statusOut-<%= item.id %>">OUT</label>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer border-0 p-4 pt-0">
          <button class="btn btn-success w-100 py-3 fw-bold rounded-3 shadow-sm">
            <i class="bi bi-check2-circle me-2"></i>UPDATE ITEM
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<% }) %>
<% } %>
<datalist id="supplierList"><% suppliers.forEach((supplier) => { %><option value="<%= supplier.supplier_name %>"></option><% }) %></datalist>
<%- include("partials/barcode-scanner-modal", { scannerModalId: "barcodeScannerModal" }) %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="/js/barcode-scanner.js"></script>
<script>
  const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" });
  const csrfToken = "<%= csrfToken %>";
  const canManageInventory = <%= user && user.role === "Admin" ? "true" : "false" %>;
  const inventorySearch = document.getElementById("inventoryLiveSearch");
  const inventoryStatus = document.getElementById("inventoryStatusFilter");
  const inventoryTableBody = document.getElementById("inventoryTableBody");
  const inventorySummary = document.getElementById("inventoryFilterSummary");
  const inventoryPrintButton = document.getElementById("inventoryPrintButton");
  const inventorySummaryTotal = document.getElementById("inventorySummaryTotal");
  const inventorySummaryInStock = document.getElementById("inventorySummaryInStock");
  const inventorySummaryLowStock = document.getElementById("inventorySummaryLowStock");
  const inventorySummaryOutOfStock = document.getElementById("inventorySummaryOutOfStock");
  let inventoryFetchController;
  let inventorySearchTimer;

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function renderInventoryRows(items) {
    if (!inventoryTableBody) return;
    if (!items.length) {
      inventoryTableBody.innerHTML = `<tr id="inventoryEmptyRow"><td colspan="4" class="text-center py-4 mini-note">No inventory items matched the current filters.</td></tr>`;
      return;
    }

    inventoryTableBody.innerHTML = items.map((item) => `
      <tr class="inventory-row">
        <td class="ps-3 py-3">
          <div class="fw-bold text-dark">${escapeHtml(item.name)}</div>
          <div class="mini-note text-muted">${escapeHtml(item.category)} | ${escapeHtml(item.supplier || "No Supplier")}</div>
          <div class="mini-note text-muted">Barcode: ${escapeHtml(item.barcode)}</div>
        </td>
        <td class="text-end">
          <div class="fw-bold text-success">${peso.format(item.selling_price)}</div>
          ${canManageInventory ? `<div class="mini-note text-muted">Cost: ${peso.format(item.unit_price)}</div>` : ""}
        </td>
        <td>
          ${item.status === "In Stock" ? '<span class="badge rounded-pill bg-success-subtle text-success px-3">IN STOCK</span>' : item.status === "Low Stock" ? '<span class="badge rounded-pill bg-warning-subtle text-warning px-3">LOW STOCK</span>' : '<span class="badge rounded-pill bg-danger-subtle text-danger px-3">OUT OF STOCK</span>'}
        </td>
        <td class="text-end pe-3">
          ${canManageInventory ? `
            <div class="d-flex justify-content-end gap-1">
              <button class="btn btn-sm btn-light rounded-circle" data-bs-toggle="modal" data-bs-target="#editItemModal-${item.id}" title="Edit">
                <i class="bi bi-pencil text-primary"></i>
              </button>
              <form method="post" action="/inventory/${item.id}/delete" onsubmit="return confirm('Delete this item?');" class="d-inline">
                <input type="hidden" name="_csrf" value="${csrfToken}">
                <button class="btn btn-sm btn-light rounded-circle" title="Delete">
                  <i class="bi bi-trash text-danger"></i>
                </button>
              </form>
            </div>
          ` : ""}
        </td>
      </tr>
    `).join("");
  }

  function updateInventorySummary(count) {
    if (!inventorySearch || !inventoryStatus || !inventorySummary) return;
    const query = inventorySearch.value.trim();
    const status = inventoryStatus.value;
    if (query || status !== "all") {
      inventorySummary.classList.remove("d-none");
      inventorySummary.textContent = `Showing ${count} ${status === "all" ? "items" : status.toLowerCase()}${query ? ` matching "${query}"` : ""}.`;
    } else {
      inventorySummary.classList.add("d-none");
      inventorySummary.textContent = "";
    }
  }

  function updateInventoryCards(summary) {
    if (!inventorySummaryTotal || !inventorySummaryInStock || !inventorySummaryLowStock || !inventorySummaryOutOfStock) return;
    inventorySummaryTotal.textContent = String(summary.total);
    inventorySummaryInStock.textContent = String(summary.inStock);
    inventorySummaryLowStock.textContent = String(summary.lowStock);
    inventorySummaryOutOfStock.textContent = String(summary.outOfStock);
  }

  async function loadInventoryResults() {
    if (!inventorySearch || !inventoryStatus || !inventoryTableBody) return;
    inventoryFetchController?.abort();
    inventoryFetchController = new AbortController();
    const params = new URLSearchParams({
      search: inventorySearch.value.trim(),
      status: inventoryStatus.value
    });

    try {
      const response = await fetch(`/api/inventory?${params.toString()}`, {
        headers: { Accept: "application/json" },
        signal: inventoryFetchController.signal
      });
      if (!response.ok) throw new Error("Failed to load inventory.");
      const payload = await response.json();
      renderInventoryRows(payload.items);
      updateInventoryCards(payload.summary);
      updateInventorySummary(payload.count);
      const url = new URL(window.location.href);
      if (payload.search) url.searchParams.set("search", payload.search); else url.searchParams.delete("search");
      if (payload.status && payload.status !== "all") url.searchParams.set("status", payload.status); else url.searchParams.delete("status");
      window.history.replaceState({}, "", url);
    } catch (error) {
      if (error.name !== "AbortError") console.error(error);
    }
  }

  if (inventorySearch) inventorySearch.addEventListener("input", () => {
    window.clearTimeout(inventorySearchTimer);
    inventorySearchTimer = window.setTimeout(loadInventoryResults, 160);
  });
  if (inventoryStatus) inventoryStatus.addEventListener("change", loadInventoryResults);
  if (inventoryPrintButton) inventoryPrintButton.addEventListener("click", () => {
    const params = new URLSearchParams({
      search: inventorySearch.value.trim(),
      status: inventoryStatus.value
    });
    window.open(`/inventory/print?${params.toString()}`, "_blank", "noopener");
  });
  if (inventorySearch) inventorySearch.addEventListener("keydown", (event) => {
    if (event.key === "Enter") {
      event.preventDefault();
      loadInventoryResults();
    }
  });
  document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((element) => {
    bootstrap.Tooltip.getOrCreateInstance(element);
  });
  const inventoryBarcodeScanner = new BarcodeScanner({ modalId: "barcodeScannerModal" });
  document.addEventListener("click", (event) => {
    const scanButton = event.target.closest(".barcode-scan-btn");
    const clearButton = event.target.closest(".barcode-clear-btn");

    if (scanButton) {
      const input = document.getElementById(scanButton.dataset.barcodeTarget);
      if (!input) return;
      inventoryBarcodeScanner.open({
        title: "Scan Product Barcode",
        onScan: (barcode) => {
          input.value = barcode;
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
        }
      });
      return;
    }

    if (clearButton) {
      const input = document.getElementById(clearButton.dataset.barcodeTarget);
      if (!input) return;
      input.value = "";
      input.dispatchEvent(new Event("input", { bubbles: true }));
      input.focus();
    }
  });

  if (inventorySearch && inventoryStatus && inventoryTableBody) loadInventoryResults();
</script>
</body>
</html>
