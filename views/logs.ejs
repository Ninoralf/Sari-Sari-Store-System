<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>
      <div class="content-card p-4 mb-4">
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <div class="section-title">Daily Logs</div>
            <div class="mini-note">Filter activity by date and search across all transaction types.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label mb-1 fw-bold small" for="logsDatePicker">Log Date</label>
            <input class="form-control border-0 bg-light shadow-sm" id="logsDatePicker" type="date" value="<%= selectedDate %>">
          </div>
          <div class="col-md-5">
            <label class="form-label mb-1 fw-bold small" for="logsSearchInput">Search Transactions</label>
            <div class="input-group shadow-sm rounded-3 overflow-hidden border-0">
              <span class="input-group-text border-0 bg-light"><i class="bi bi-search text-muted"></i></span>
              <input class="form-control border-0 bg-light" id="logsSearchInput" placeholder="Search code, number, or employee...">
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <!-- PRODUCT LOGS -->
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
              <div>
                <div class="section-title">Product Logs</div>
                <div class="mini-note">Non-load item transactions for the selected date.</div>
              </div>
              <div class="d-flex flex-wrap gap-2 justify-content-end" id="productLogsSummary">
                <div class="content-card border p-3 text-start bg-light-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold" style="font-size: 0.6rem;">Total Sales</div>
                  <div class="fw-bold h5 mb-0 text-success"><%= formatCurrency(logs.summary.productTotal) %></div>
                  <div class="mini-note"><%= logs.summary.productCount %> entries</div>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                  <tr>
                    <th class="ps-3">Log ID</th>
                    <th>Transaction</th>
                    <th class="text-end">Total Amount</th>
                    <th>Employee</th>
                    <th>Time Stamp</th>
                    <th class="text-end pe-3">Items</th>
                  </tr>
                </thead>
                <tbody id="productLogsBody">
                  <% if (logs.productLogs.length) { %>
                    <% logs.productLogs.forEach((entry) => { %>
                      <tr class="log-row" data-search="<%= (entry.transactionCode + ' ' + (entry.employee || '')).toLowerCase() %>">
                        <td class="ps-3 font-monospace small text-muted">#<%= entry.logId %></td>
                        <td class="fw-bold text-dark"><%= entry.transactionCode %></td>
                        <td class="text-end fw-bold"><%= formatCurrency(entry.totalAmount) %></td>
                        <td><span class="badge bg-light text-dark border-0"><%= entry.employee || "-" %></span></td>
                        <td><div class="small"><%= formatDateTime(entry.timeStamp) %></div></td>
                        <td class="text-end pe-3">
                          <button
                            class="btn btn-sm btn-light rounded-circle product-log-popover shadow-sm"
                            type="button"
                            data-bs-toggle="popover"
                            data-bs-trigger="focus"
                            data-bs-placement="left"
                            data-log-id="<%= entry.logId %>"
                            data-log-items='<%- JSON.stringify(entry.items) %>'
                          >
                            <i class="bi bi-list-ul text-primary"></i>
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="6" class="text-center py-5 opacity-50"><i class="bi bi-inbox display-6 d-block mb-2"></i>No product logs for this date.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ELOAD LOGS -->
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
              <div>
                <div class="section-title">Eload Logs</div>
                <div class="mini-note">Digital load service history.</div>
              </div>
              <div class="d-flex flex-wrap gap-2 justify-content-end" id="eloadLogsSummary">
                <div class="content-card border p-3 text-start bg-light-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold" style="font-size: 0.6rem;">Volume</div>
                  <div class="fw-bold h5 mb-0"><%= formatCurrency(logs.summary.eloadTotal) %></div>
                  <div class="mini-note"><%= logs.summary.eloadCount %> entries</div>
                </div>
                <div class="content-card border p-3 text-start bg-success-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold text-success" style="font-size: 0.6rem;">Completed</div>
                  <div class="fw-bold h5 mb-0 text-success"><%= formatCurrency(logs.summary.eloadCompletedTotal) %></div>
                  <div class="mini-note"><%= logs.summary.eloadCompletedCount %> entries</div>
                </div>
                <div class="content-card border p-3 text-start bg-warning-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold text-warning-emphasis" style="font-size: 0.6rem;">Failed</div>
                  <div class="fw-bold h5 mb-0 text-warning-emphasis"><%= formatCurrency(logs.summary.eloadFailedTotal) %></div>
                  <div class="mini-note"><%= logs.summary.eloadFailedCount %> entries</div>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                  <tr>
                    <th class="ps-3">Request</th>
                    <th>Number</th>
                    <th>Network</th>
                    <th>Load Item</th>
                    <th>Staff Info</th>
                    <th>Status</th>
                    <th class="text-end pe-3">Amount</th>
                  </tr>
                </thead>
                <tbody id="eloadLogsBody">
                  <% if (logs.eloadLogs.length) { %>
                    <% logs.eloadLogs.forEach((entry) => { %>
                      <tr class="log-row" data-search="<%= (entry.requestCode + ' ' + (entry.number || '') + ' ' + (entry.requestedBy || '') + ' ' + (entry.completedBy || '')).toLowerCase() %>">
                        <td class="ps-3 fw-bold text-dark font-monospace"><%= entry.requestCode %></td>
                        <td class="fw-bold"><%= entry.number || "-" %></td>
                        <td><span class="badge bg-success-subtle text-success border-0 px-2"><%= entry.network || "-" %></span></td>
                        <td class="small"><%= entry.loadValue || "-" %></td>
                        <td>
                          <div class="small fw-bold"><%= entry.requestedBy || "-" %></div>
                          <div class="mini-note text-muted"><%= formatDateTime(entry.requestedAt) %></div>
                        </td>
                        <td><span class="badge rounded-pill <%= entry.status === "Completed" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning" %> px-3"><%= entry.status.toUpperCase() %></span></td>
                        <td class="text-end pe-3 fw-bold text-success"><%= formatCurrency(entry.amount) %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="8" class="text-center py-5 opacity-50"><i class="bi bi-inbox display-6 d-block mb-2"></i>No eload logs for this date.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- GCASH LOGS -->
        <div class="col-12">
          <div class="content-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
              <div>
                <div class="section-title">GCash Logs</div>
                <div class="mini-note">Cash-in and cash-out activity.</div>
              </div>
              <div class="d-flex flex-wrap gap-2 justify-content-end" id="gcashLogsSummary">
                <div class="content-card border p-3 text-start bg-light-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold" style="font-size: 0.6rem;">Volume</div>
                  <div class="fw-bold h5 mb-0"><%= formatCurrency(logs.summary.gcashTotal) %></div>
                  <div class="mini-note"><%= logs.summary.gcashCount %> entries</div>
                </div>
                <div class="content-card border p-3 text-start bg-success-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold text-success" style="font-size: 0.6rem;">Completed</div>
                  <div class="fw-bold h5 mb-0 text-success"><%= formatCurrency(logs.summary.gcashCompletedTotal) %></div>
                  <div class="mini-note"><%= logs.summary.gcashCompletedCount %> entries</div>
                </div>
                <div class="content-card border p-3 text-start bg-warning-subtle" style="min-width: 140px;">
                  <div class="mini-note text-uppercase fw-bold text-warning-emphasis" style="font-size: 0.6rem;">Failed</div>
                  <div class="fw-bold h5 mb-0 text-warning-emphasis"><%= formatCurrency(logs.summary.gcashFailedTotal) %></div>
                  <div class="mini-note"><%= logs.summary.gcashFailedCount %> entries</div>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table align-middle mb-0 table-hover">
                <thead class="table-light">
                  <tr>
                    <th class="ps-3">Request</th>
                    <th>Number</th>
                    <th>Reference No.</th>
                    <th>Type</th>
                    <th>Staff Info</th>
                    <th>Status</th>
                    <th class="text-end pe-3">Paid</th>
                  </tr>
                </thead>
                <tbody id="gcashLogsBody">
                  <% if (logs.gcashLogs.length) { %>
                    <% logs.gcashLogs.forEach((entry) => { %>
                      <tr class="log-row" data-search="<%= (entry.requestCode + ' ' + (entry.number || '') + ' ' + (entry.referenceNo || '') + ' ' + (entry.requestedBy || '') + ' ' + (entry.completedBy || '')).toLowerCase() %>">
                        <td class="ps-3 fw-bold text-dark font-monospace"><%= entry.requestCode %></td>
                        <td class="fw-bold"><%= entry.number || "-" %></td>
                        <td class="small font-monospace text-muted"><%= entry.referenceNo || "-" %></td>
                        <td><span class="badge <%= entry.requestKind === 'Cash In' ? 'bg-primary-subtle text-primary' : 'bg-info-subtle text-info' %> border-0 px-2"><%= entry.requestKind || "Cash In" %></span></td>
                        <td>
                          <div class="small fw-bold"><%= entry.requestedBy || "-" %></div>
                          <div class="mini-note text-muted"><%= formatDateTime(entry.requestedAt) %></div>
                        </td>
                        <td><span class="badge rounded-pill <%= entry.status === "Completed" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning" %> px-3"><%= entry.status.toUpperCase() %></span></td>
                        <td class="text-end pe-3 fw-bold text-success"><%= formatCurrency(entry.totalAmount) %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="8" class="text-center py-5 opacity-50"><i class="bi bi-inbox display-6 d-block mb-2"></i>No GCash logs for this date.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const logsDatePicker = document.getElementById("logsDatePicker");
  const logsSearchInput = document.getElementById("logsSearchInput");
  const productLogsBody = document.getElementById("productLogsBody");
  const eloadLogsBody = document.getElementById("eloadLogsBody");
  const gcashLogsBody = document.getElementById("gcashLogsBody");
  const productLogsSummary = document.getElementById("productLogsSummary");
  const eloadLogsSummary = document.getElementById("eloadLogsSummary");
  const gcashLogsSummary = document.getElementById("gcashLogsSummary");
  const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" });
  let logsFetchController;

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function formatDateTimeClient(value) {
    if (!value) return "-";
    return new Date(`${String(value).replace(" ", "T")}Z`).toLocaleString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
      hour: "numeric",
      minute: "2-digit",
      timeZone: "Asia/Manila"
    });
  }

  function handleSearch() {
    const query = logsSearchInput.value.toLowerCase().trim();
    document.querySelectorAll(".log-row").forEach(row => {
      const text = row.dataset.search || "";
      row.classList.toggle("d-none", query && !text.includes(query));
    });
  }

  function renderRows(body, rows, emptyMessage, columns, formatter) {
    if (!rows.length) {
      body.innerHTML = `<tr><td colspan="${columns}" class="text-center py-5 opacity-50"><i class="bi bi-inbox display-6 d-block mb-2"></i>${emptyMessage}</td></tr>`;
      return;
    }
    body.innerHTML = formatter(rows);
    handleSearch(); // Re-apply current search filter
  }

  function renderProductPopoverContent(items) {
    if (!items?.length) {
      return '<div class="mini-note text-center p-3">No purchased products recorded.</div>';
    }

    return `
      <div class="fw-bold mb-2 small text-uppercase text-muted">Purchased Products</div>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0" style="font-size: 0.85rem;">
          <thead class="table-light">
            <tr>
              <th>Product</th>
              <th class="text-end">Qty</th>
              <th class="text-end">Amount</th>
            </tr>
          </thead>
          <tbody>
            ${items.map((item) => `
              <tr>
                <td>${escapeHtml(item.itemName)}</td>
                <td class="text-end">${item.quantity}</td>
                <td class="text-end fw-bold">${peso.format(item.amount)}</td>
              </tr>
            `).join("")}
          </tbody>
        </table>
      </div>
    `;
  }

  function bindProductLogPopovers() {
    if (typeof bootstrap === "undefined") return;

    document.querySelectorAll(".product-log-popover").forEach((button) => {
      const items = JSON.parse(button.dataset.logItems || "[]");
      bootstrap.Popover.getOrCreateInstance(button, {
        html: true,
        sanitize: false,
        customClass: "product-log-popover-card shadow-lg",
        content: renderProductPopoverContent(items)
      });
    });
  }

  async function loadLogs(date) {
    logsFetchController?.abort();
    logsFetchController = new AbortController();
    try {
      const response = await fetch(`/api/logs?date=${encodeURIComponent(date)}`, {
        headers: { Accept: "application/json" },
        signal: logsFetchController.signal
      });
      if (!response.ok) throw new Error("Failed to load logs.");
      const payload = await response.json();

      productLogsSummary.innerHTML = `
        <div class="content-card border p-3 text-start bg-light-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold" style="font-size: 0.6rem;">Total Sales</div>
          <div class="fw-bold h5 mb-0 text-success">${peso.format(payload.summary.productTotal)}</div>
          <div class="mini-note">${payload.summary.productCount} entries</div>
        </div>
      `;

      eloadLogsSummary.innerHTML = `
        <div class="content-card border p-3 text-start bg-light-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold" style="font-size: 0.6rem;">Volume</div>
          <div class="fw-bold h5 mb-0">${peso.format(payload.summary.eloadTotal)}</div>
          <div class="mini-note">${payload.summary.eloadCount} entries</div>
        </div>
        <div class="content-card border p-3 text-start bg-success-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold text-success" style="font-size: 0.6rem;">Completed</div>
          <div class="fw-bold h5 mb-0 text-success">${peso.format(payload.summary.eloadCompletedTotal)}</div>
          <div class="mini-note">${payload.summary.eloadCompletedCount} entries</div>
        </div>
        <div class="content-card border p-3 text-start bg-warning-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold text-warning-emphasis" style="font-size: 0.6rem;">Failed</div>
          <div class="fw-bold h5 mb-0 text-warning-emphasis">${peso.format(payload.summary.eloadFailedTotal)}</div>
          <div class="mini-note">${payload.summary.eloadFailedCount} entries</div>
        </div>
      `;

      gcashLogsSummary.innerHTML = `
        <div class="content-card border p-3 text-start bg-light-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold" style="font-size: 0.6rem;">Volume</div>
          <div class="fw-bold h5 mb-0">${peso.format(payload.summary.gcashTotal)}</div>
          <div class="mini-note">${payload.summary.gcashCount} entries</div>
        </div>
        <div class="content-card border p-3 text-start bg-success-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold text-success" style="font-size: 0.6rem;">Completed</div>
          <div class="fw-bold h5 mb-0 text-success">${peso.format(payload.summary.gcashCompletedTotal)}</div>
          <div class="mini-note">${payload.summary.gcashCompletedCount} entries</div>
        </div>
        <div class="content-card border p-3 text-start bg-warning-subtle" style="min-width: 140px;">
          <div class="mini-note text-uppercase fw-bold text-warning-emphasis" style="font-size: 0.6rem;">Failed</div>
          <div class="fw-bold h5 mb-0 text-warning-emphasis">${peso.format(payload.summary.gcashFailedTotal)}</div>
          <div class="mini-note">${payload.summary.gcashFailedCount} entries</div>
        </div>
      `;

      renderRows(productLogsBody, payload.productLogs, "No product logs for this date.", 6, (rows) => rows.map((entry) => `
        <tr class="log-row" data-search="${(entry.transactionCode + ' ' + (entry.employee || '')).toLowerCase()}">
          <td class="ps-3 font-monospace small text-muted">#${entry.logId}</td>
          <td class="fw-bold text-dark">${escapeHtml(entry.transactionCode)}</td>
          <td class="text-end fw-bold">${peso.format(entry.totalAmount)}</td>
          <td><span class="badge bg-light text-dark border-0">${escapeHtml(entry.employee || "-")}</span></td>
          <td><div class="small">${escapeHtml(formatDateTimeClient(entry.timeStamp))}</div></td>
          <td class="text-end pe-3">
            <button
              class="btn btn-sm btn-light rounded-circle product-log-popover shadow-sm"
              type="button"
              data-bs-toggle="popover"
              data-bs-trigger="focus"
              data-bs-placement="left"
              data-log-id="${entry.logId}"
              data-log-items='${escapeHtml(JSON.stringify(entry.items || []))}'
            >
              <i class="bi bi-list-ul text-primary"></i>
            </button>
          </td>
        </tr>
      `).join(""));
      bindProductLogPopovers();

      renderRows(eloadLogsBody, payload.eloadLogs, "No eload logs for this date.", 8, (rows) => rows.map((entry) => `
        <tr class="log-row" data-search="${(entry.requestCode + ' ' + (entry.number || '') + ' ' + (entry.requestedBy || '') + ' ' + (entry.completedBy || '')).toLowerCase()}">
          <td class="ps-3 fw-bold text-dark font-monospace">${escapeHtml(entry.requestCode)}</td>
          <td class="fw-bold">${escapeHtml(entry.number || "-")}</td>
          <td><span class="badge bg-success-subtle text-success border-0 px-2">${escapeHtml(entry.network || "-")}</span></td>
          <td class="small">${escapeHtml(entry.loadValue || "-")}</td>
          <td>
            <div class="small fw-bold">${escapeHtml(entry.requestedBy || "-")}</div>
            <div class="mini-note text-muted">${escapeHtml(formatDateTimeClient(entry.requestedAt))}</div>
          </td>
          <td><span class="badge rounded-pill ${entry.status === "Completed" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning"} px-3">${escapeHtml(entry.status.toUpperCase())}</span></td>
          <td class="text-end pe-3 fw-bold text-success">${peso.format(entry.amount)}</td>
        </tr>
      `).join(""));

      renderRows(gcashLogsBody, payload.gcashLogs, "No GCash logs for this date.", 8, (rows) => rows.map((entry) => `
        <tr class="log-row" data-search="${(entry.requestCode + ' ' + (entry.number || '') + ' ' + (entry.referenceNo || '') + ' ' + (entry.requestedBy || '') + ' ' + (entry.completedBy || '')).toLowerCase()}">
          <td class="ps-3 fw-bold text-dark font-monospace">${escapeHtml(entry.requestCode)}</td>
          <td class="fw-bold">${escapeHtml(entry.number || "-")}</td>
          <td class="small font-monospace text-muted">${escapeHtml(entry.referenceNo || "-")}</td>
          <td><span class="badge ${entry.requestKind === 'Cash In' ? 'bg-primary-subtle text-primary' : 'bg-info-subtle text-info'} border-0 px-2">${escapeHtml(entry.requestKind || "Cash In")}</span></td>
          <td>
            <div class="small fw-bold">${escapeHtml(entry.requestedBy || "-")}</div>
            <div class="mini-note text-muted">${escapeHtml(formatDateTimeClient(entry.requestedAt))}</div>
          </td>
          <td><span class="badge rounded-pill ${entry.status === "Completed" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning"} px-3">${escapeHtml(entry.status.toUpperCase())}</span></td>
          <td class="text-end pe-3 fw-bold text-success">${peso.format(entry.totalAmount)}</td>
        </tr>
      `).join(""));

      const url = new URL(window.location.href);
      url.searchParams.set("date", payload.selectedDate);
      window.history.replaceState({}, "", url);
    } catch (error) {
      if (error.name !== "AbortError") console.error(error);
    }
  }

  logsDatePicker.addEventListener("change", () => {
    if (!logsDatePicker.value) return;
    loadLogs(logsDatePicker.value);
  });

  logsSearchInput.addEventListener("input", handleSearch);

  bindProductLogPopovers();
</script>
</body>
</html>
