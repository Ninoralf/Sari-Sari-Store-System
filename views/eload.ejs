<%- include("partials/head") %>
<div class="app-shell d-lg-flex">
  <%- include("partials/sidebar") %>
  <main class="flex-grow-1">
    <%- include("partials/topbar") %>
    <section class="p-3 p-lg-4">
      <%- include("partials/flash") %>

      <!-- View Toggle Switch -->
      <div class="d-flex justify-content-center mb-4">
        <div class="nav nav-pills bg-light p-1 rounded-pill shadow-sm" style="width: 440px; max-width: 100%;" role="tablist">
          <button class="nav-link active rounded-pill py-2 border-0 flex-grow-1" id="nav-request-tab" data-bs-toggle="tab" data-bs-target="#view-request" type="button" role="tab" aria-controls="view-request" aria-selected="true">
            <i class="bi bi-plus-circle me-2"></i>Request
          </button>
          <button class="nav-link rounded-pill py-2 border-0 flex-grow-1 position-relative" id="nav-queue-tab" data-bs-toggle="tab" data-bs-target="#view-queue" type="button" role="tab" aria-controls="view-queue" aria-selected="false">
            <i class="bi bi-clock-history me-2"></i>Queue
            <% const pendingCount = requests.filter(r => r.status === 'Pending').length; %>
            <% if (pendingCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.65rem;">
                <%= pendingCount %>
              </span>
            <% } %>
          </button>
          <% if (user && user.role === "Admin") { %>
            <button class="nav-link rounded-pill py-2 border-0 flex-grow-1" id="nav-set-tab" data-bs-toggle="tab" data-bs-target="#view-set" type="button" role="tab" aria-controls="view-set" aria-selected="false">
              <i class="bi bi-sliders me-2"></i>SET
            </button>
          <% } %>
        </div>
      </div>

      <div class="tab-content" id="eloadViewContent" style="min-height: 400px;">
        <!-- REQUEST VIEW -->
        <div class="tab-pane fade show active" id="view-request" role="tabpanel" aria-labelledby="nav-request-tab">
          <div class="row g-4">
            <!-- Input Section -->
            <div class="col-xl-6 mx-auto">
              <div class="content-card p-4">
                <div class="mb-4">
                  <div class="section-title">New Request</div>
                  <div class="mini-note">Create a new digital service transaction.</div>
                </div>

                <!-- STEP 1 -->
                <div class="mb-4">
                  <div class="d-flex align-items-center gap-3 mb-3">
                    <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">1</span>
                    <span class="fw-bold text-uppercase small">Choose Service Type</span>
                  </div>
                  <div class="nav nav-pills nav-fill bg-light p-1 rounded-pill" role="tablist">
                    <button class="nav-link active rounded-pill py-2 border-0" id="tab-eload" data-bs-toggle="tab" data-bs-target="#panel-eload" type="button" role="tab"><i class="bi bi-phone me-2"></i>eLoad</button>
                    <button class="nav-link rounded-pill py-2 border-0" id="tab-gcash" data-bs-toggle="tab" data-bs-target="#panel-gcash" type="button" role="tab"><i class="bi bi-wallet2 me-2"></i>GCash</button>
                  </div>
                </div>

            <div class="tab-content">
              <!-- eLoad Panel -->
              <div class="tab-pane fade show active" id="panel-eload" role="tabpanel">
                <form id="eloadForm" action="/eload/requests" method="post" class="row g-3">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="serviceType" value="eload">
                  <input type="hidden" name="network" id="eloadNetworkValue">
                  <input type="hidden" name="loadValue" id="eloadLoadValue">
                  <input type="hidden" name="amount" id="eloadAmountValue">

                  <!-- STEP 2 -->
                  <div class="col-12">
                    <div class="d-flex align-items-center gap-3 mb-2">
                      <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">2</span>
                      <span class="fw-bold text-uppercase small">Enter Mobile Number</span>
                    </div>
                    <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                      <span class="input-group-text border-0 bg-white"><i class="bi bi-phone text-muted"></i></span>
                      <input class="form-control border-0" id="eloadMobileNumber" name="mobileNumber" inputmode="numeric" maxlength="13" placeholder="09XX XXX XXXX" required>
                    </div>
                  </div>

                  <!-- STEP 3 -->
                  <div class="col-12">
                    <div class="d-flex align-items-center gap-3 mb-2">
                      <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">3</span>
                      <span class="fw-bold text-uppercase small">Select Network</span>
                    </div>
                    <div class="row g-2" id="eloadNetworkGrid">
                      <!-- Rendered by JS -->
                    </div>
                  </div>

                  <!-- STEP 4 -->
                  <div class="col-12">
                    <div class="d-flex align-items-center gap-3 mb-2">
                      <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">4</span>
                      <span class="fw-bold text-uppercase small">Choose Load & Finish</span>
                    </div>
                    <div class="bg-light p-3 rounded-4">
                      <div class="d-flex gap-2 mb-3">
                        <input class="btn-check" type="radio" name="loadType" id="typePromo" value="promo" checked>
                        <label class="btn btn-outline-primary btn-sm rounded-pill px-3" for="typePromo">Promo</label>
                        <input class="btn-check" type="radio" name="loadType" id="typeRegular" value="regular">
                        <label class="btn btn-outline-primary btn-sm rounded-pill px-3" for="typeRegular">Regular</label>
                      </div>
                      
                      <div id="promoGroup">
                        <select class="form-select border-0 shadow-sm" id="eloadPromoSelect" disabled>
                          <option value="">Choose network first</option>
                        </select>
                      </div>
                      
                      <div id="regularGroup" class="d-none">
                        <div class="input-group shadow-sm">
                          <span class="input-group-text border-0 bg-white">₱</span>
                          <input class="form-control border-0" id="eloadRegularAmount" type="number" min="1" placeholder="Enter amount">
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-12">
                    <label class="form-label fw-bold small">Notes (Optional)</label>
                    <textarea class="form-control bg-light border-0" name="notes" rows="2" placeholder="e.g. 'Wait for confirmation'"></textarea>
                  </div>

                  <div class="col-12 mt-4">
                    <div class="d-flex gap-2">
                      <button class="btn btn-primary flex-grow-1 py-3 fw-bold rounded-3 shadow-sm" type="submit">QUEUE REQUEST</button>
                      <button class="btn btn-success px-4 rounded-3 shadow-sm" type="button" id="eloadAddToCartButton" title="Add to POS Cart"><i class="bi bi-cart-plus fs-4"></i></button>
                    </div>
                  </div>
                </form>
              </div>

              <!-- GCash Panel -->
              <div class="tab-pane fade" id="panel-gcash">
                <form id="gcashForm" action="/eload/requests" method="post" class="row g-3">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="serviceType" value="gcash">

                  <!-- STEP 2 -->
                  <div class="col-12">
                    <div class="d-flex align-items-center gap-3 mb-2">
                      <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">2</span>
                      <span class="fw-bold text-uppercase small">Choose Transaction Flow</span>
                    </div>
                    <div class="row g-2">
                      <input class="btn-check" type="radio" name="cashFlow" id="flowIn" value="Cash In" checked>
                      <div class="col-6">
                        <label class="gcash-flow-option gcash-flow-in h-100" for="flowIn">
                          <span class="gcash-flow-icon"><i class="bi bi-arrow-down-circle"></i></span>
                          <span>
                            <span class="gcash-flow-title">Cash In</span>
                            <span class="gcash-flow-note">Receive money</span>
                          </span>
                        </label>
                      </div>
                      <input class="btn-check" type="radio" name="cashFlow" id="flowOut" value="Cash Out">
                      <div class="col-6">
                        <label class="gcash-flow-option gcash-flow-out h-100" for="flowOut">
                          <span class="gcash-flow-icon"><i class="bi bi-arrow-up-circle"></i></span>
                          <span>
                            <span class="gcash-flow-title">Cash Out</span>
                            <span class="gcash-flow-note">Release money</span>
                          </span>
                        </label>
                      </div>
                    </div>
                  </div>

                  <!-- STEP 3 -->
                  <div class="col-12">
                    <div class="d-flex align-items-center gap-3 mb-2">
                      <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">3</span>
                      <span class="fw-bold text-uppercase small">Enter GCash Details</span>
                    </div>
                    <div class="mb-3">
                      <label class="form-label small fw-bold">Mobile Number</label>
                      <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                        <span class="input-group-text border-0 bg-white"><i class="bi bi-wallet2 text-muted"></i></span>
                        <input class="form-control border-0" id="gcashMobileNumber" name="mobileNumber" inputmode="numeric" maxlength="13" placeholder="09XX XXX XXXX" required>
                      </div>
                    </div>
                    <div>
                      <label class="form-label small fw-bold">Amount</label>
                      <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                        <span class="input-group-text border-0 bg-white">₱</span>
                        <input class="form-control border-0" name="amount" type="number" min="1" step="1" placeholder="0.00" required>
                      </div>
                    </div>
                  </div>

                  <!-- STEP 4 -->
                  <div class="col-12">
                    <div class="d-flex align-items-center gap-3 mb-2">
                      <span class="badge rounded-circle bg-dark text-white d-inline-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">4</span>
                      <span class="fw-bold text-uppercase small">Additional Info & Finish</span>
                    </div>
                    <div class="mb-3">
                      <label class="form-label small fw-bold">Reference Number (Optional)</label>
                      <input class="form-control bg-light border-0 py-2" name="referenceNumber" placeholder="Enter if already known">
                    </div>
                    <div class="mb-3">
                      <label class="form-label small fw-bold">Notes (Optional)</label>
                      <textarea class="form-control bg-light border-0" name="notes" rows="2" placeholder="e.g. 'Customer is at the store'"></textarea>
                    </div>
                    <button class="btn btn-primary w-100 py-3 fw-bold rounded-3 shadow-sm" type="submit">QUEUE GCASH REQUEST</button>
                  </div>
                </form>
              </div>
            </div> <!-- End Inner Tab Content -->
          </div> <!-- End Content Card -->
        </div> <!-- End Col -->
      </div> <!-- End Row -->
    </div> <!-- End View Request Tab Pane -->

    <!-- QUEUE VIEW -->
    <div class="tab-pane fade" id="view-queue" role="tabpanel">
          <div class="row g-4">
            <!-- Pending Section -->
            <div class="col-lg-6">
              <div class="content-card p-4 h-100">
                <div class="mb-4">
                  <div class="section-title">Pending Queue</div>
                  <div class="mini-note">Requests waiting for fulfillment.</div>
                </div>

                <div class="vstack gap-3" id="pendingQueueList">
                  <% const pending = requests.filter(r => r.status === 'Pending'); %>
                  <% if (!pending.length) { %>
                    <div class="text-center py-5 opacity-50">
                      <i class="bi bi-hourglass-split display-1 d-block mb-3"></i>
                      <div class="fw-bold text-muted">Queue is empty</div>
                    </div>
                  <% } else { %>
                    <% pending.forEach(req => { %>
                      <div class="request-card p-3 bg-white rounded-4 border shadow-sm border-start border-4 <%= req.service_type === 'gcash' ? 'border-primary' : 'border-success' %>">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                          <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                              <span class="badge <%= req.service_type === 'gcash' ? 'bg-primary' : 'bg-success' %> text-uppercase small" style="font-size: 0.6rem;"><%= req.service_type %></span>
                              <span class="fw-bold text-dark small"><%= req.request_code %></span>
                            </div>
                            <div class="h5 mb-0 fw-bold font-monospace"><%= req.mobile_number %></div>
                            <div class="mini-note text-muted"><%= req.service_type === 'gcash' ? req.request_kind : `${req.network} | ${req.load_value}` %></div>
                          </div>
                          <div class="text-end">
                            <div class="h4 mb-0 fw-bold text-success">₱<%= req.amount.toLocaleString() %></div>
                            <div class="mini-note">by <%= req.requested_by_name %></div>
                          </div>
                        </div>

                        <% if (req.notes) { %>
                          <div class="bg-light p-2 rounded mb-3 border-start border-3 border-warning">
                            <div class="mini-note fw-bold text-warning-emphasis">NOTE:</div>
                            <div class="small"><%= req.notes %></div>
                          </div>
                        <% } %>

                        <div class="d-flex gap-2">
                          <button class="btn btn-sm btn-dark flex-grow-1 py-2 fw-bold rounded-pill" data-bs-toggle="collapse" data-bs-target="#complete-<%= req.id %>">
                            <i class="bi bi-check2-circle me-1"></i>FULFILL
                          </button>
                          <button class="btn btn-sm btn-outline-danger px-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#failRequestModal" data-request-id="<%= req.id %>" data-request-code="<%= req.request_code %>">
                            <i class="bi bi-x-circle"></i>
                          </button>
                          <button class="btn btn-sm btn-outline-secondary px-3 rounded-pill" onclick="copyToClipboard('<%= req.mobile_number %>', this)" title="Copy Number">
                            <i class="bi bi-clipboard"></i>
                          </button>
                        </div>

                        <div class="collapse mt-3" id="complete-<%= req.id %>">
                          <form action="/eload/requests/<%= req.id %>/complete" method="post" class="bg-light p-3 rounded-3 border">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <% if (req.service_type === 'gcash') { %>
                              <label class="form-label small fw-bold">Reference Number (Optional)</label>
                              <div class="input-group shadow-sm mb-2">
                                <input class="form-control form-control-sm border-0" name="referenceNumber" placeholder="Enter Ref # if any">
                              </div>
                            <% } %>
                            <button class="btn btn-sm btn-success w-100 fw-bold">CONFIRM FULFILLMENT</button>
                            <div class="mini-note mt-2 text-center text-secondary">Verify transaction before saving.</div>
                          </form>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Recent History Section -->
            <div class="col-lg-6">
              <div class="content-card p-4 h-100">
                <div class="mb-4">
                  <div class="section-title">Recent Requests</div>
                  <div class="mini-note">History of processed transactions.</div>
                </div>

                <div class="vstack gap-3">
                  <%
                    const todayKey = new Date().toLocaleDateString("en-CA", { timeZone: "Asia/Manila" });
                    const recent = requests
                      .filter((r) => {
                        if (r.status === "Pending") return false;
                        const resolvedAt = r.status === "Completed" ? r.completed_at : r.failed_at;
                        if (!resolvedAt) return false;
                        const resolvedDate = new Date(`${String(resolvedAt).replace(" ", "T")}Z`);
                        const resolvedKey = resolvedDate.toLocaleDateString("en-CA", { timeZone: "Asia/Manila" });
                        return resolvedKey === todayKey;
                      })
                      .reverse()
                      .slice(0, 10);
                  %>
                  <% if (!recent.length) { %>
                    <div class="text-center py-5 opacity-50">
                      <div class="fw-bold text-muted">No history yet</div>
                    </div>
                  <% } else { %>
                    <% recent.forEach(req => { %>
                      <div class="p-3 bg-light rounded-4 border-start border-4 <%= req.status === 'Completed' ? 'border-success' : 'border-danger' %>">
                        <div class="d-flex justify-content-between align-items-center">
                          <div class="d-flex align-items-center gap-3">
                            <div>
                              <div class="fw-bold"><%= req.mobile_number %></div>
                              <div class="mini-note text-muted"><%= req.service_type.toUpperCase() %> | <%= req.status %></div>
                            </div>
                            <button class="btn btn-sm btn-link text-secondary p-0" onclick="copyToClipboard('<%= req.mobile_number %>', this)" title="Copy Number">
                              <i class="bi bi-clipboard small"></i>
                            </button>
                          </div>
                          <div class="text-end">
                            <div class="fw-bold">₱<%= req.amount.toLocaleString() %></div>
                            <div class="small text-muted"><%= req.request_code %></div>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% if (user && user.role === "Admin") { %>
        <div class="tab-pane fade" id="view-set" role="tabpanel" aria-labelledby="nav-set-tab">
          <div class="content-card p-4 mb-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
              <div>
                <div class="section-title">eLoad Networks</div>
                <div class="mini-note">Manage networks and the promo list shown in the eLoad request tab.</div>
              </div>
              <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addEloadNetworkModal"><i class="bi bi-plus-lg me-2"></i>Add Network</button>
            </div>
            <% if (!eloadNetworks.length) { %>
              <div class="text-center py-4 mini-note">No eLoad networks added yet.</div>
            <% } else { %>
              <div class="vstack gap-3">
                <% eloadNetworks.forEach((network) => { %>
                  <div class="border rounded-4 p-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                      <div>
                        <div class="fw-bold fs-5"><%= network.network_name %></div>
                        <div class="mini-note"><%= network.promos.length %> promo<%= network.promos.length === 1 ? '' : 's' %></div>
                      </div>
                      <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#addEloadPromoModal-<%= network.network_id %>"><i class="bi bi-plus-lg me-1"></i>Add Promo</button>
                        <form method="post" action="/settings/eload/networks/<%= network.network_id %>/delete" onsubmit="return confirm('Delete this network and all of its promos?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                      </div>
                    </div>
                    <div class="table-responsive">
                      <table class="table align-middle mb-0">
                        <thead>
                          <tr>
                            <th>Promo Name</th>
                            <th class="text-end">Selling Price</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% if (!network.promos.length) { %>
                            <tr><td colspan="3" class="text-center py-3 mini-note">No promos added for this network.</td></tr>
                          <% } else { %>
                            <% network.promos.forEach((promo) => { %>
                              <tr>
                                <td class="fw-semibold"><%= promo.promo_name %></td>
                                <td class="text-end">₱<%= Number(promo.selling_price || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                <td class="text-end">
                                  <button class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#editEloadPromoModal-<%= promo.promo_id %>"><i class="bi bi-pencil"></i></button>
                                  <form class="d-inline" method="post" action="/settings/eload/promos/<%= promo.promo_id %>/delete" onsubmit="return confirm('Delete this promo?');">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                  </form>
                                </td>
                              </tr>
                            <% }) %>
                          <% } %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </section>
    <%- include("partials/footer") %>
  </main>
</div>
<div class="modal fade" id="failRequestModal" tabindex="-1" aria-labelledby="failRequestModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form method="post" id="failRequestForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header">
          <h5 class="modal-title" id="failRequestModalLabel">Mark Request as Failed</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mini-note mb-3">Please provide the reason why this request failed.</div>
          <div class="fw-semibold mb-3" id="failRequestCodeText">Request</div>
          <div>
            <label class="form-label" for="failedReasonInput">Failure Reason</label>
            <textarea class="form-control" id="failedReasonInput" name="failedReason" rows="3" placeholder="e.g. Wrong mobile number, unavailable network, customer cancelled" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-danger">Confirm Failed Status</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% if (user && user.role === "Admin") { %>
<div class="modal fade" id="addEloadNetworkModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form method="post" action="/settings/eload/networks/add">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header"><h5 class="modal-title">Add eLoad Network</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <label class="form-label">Network Name</label>
          <input class="form-control text-uppercase" name="networkName" placeholder="e.g. SNT" required>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-success">Save Network</button></div>
      </form>
    </div>
  </div>
</div>
<% eloadNetworks.forEach((network) => { %>
  <div class="modal fade" id="addEloadPromoModal-<%= network.network_id %>" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form method="post" action="/settings/eload/promos/add">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="networkId" value="<%= network.network_id %>">
          <div class="modal-header"><h5 class="modal-title">Add Promo for <%= network.network_name %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-7"><label class="form-label">Promo Name</label><input class="form-control" name="promoName" placeholder="e.g. SNT30" required></div>
              <div class="col-md-5"><label class="form-label">Selling Price</label><input class="form-control" name="sellingPrice" type="number" min="1" step="0.01" placeholder="0.00" required></div>
            </div>
          </div>
          <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-success">Save Promo</button></div>
        </form>
      </div>
    </div>
  </div>
  <% network.promos.forEach((promo) => { %>
    <div class="modal fade" id="editEloadPromoModal-<%= promo.promo_id %>" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <form method="post" action="/settings/eload/promos/<%= promo.promo_id %>/update">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="modal-header"><h5 class="modal-title">Edit Promo for <%= network.network_name %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-7"><label class="form-label">Promo Name</label><input class="form-control" name="promoName" value="<%= promo.promo_name %>" required></div>
                <div class="col-md-5"><label class="form-label">Selling Price</label><input class="form-control" name="sellingPrice" type="number" min="1" step="0.01" value="<%= promo.selling_price %>" required></div>
              </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-success">Update Promo</button></div>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
<% }) %>
<% } %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const networkPromos = <%- JSON.stringify(eloadPromoCatalog || {}) %>;

  const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" });
  const eloadForm = document.getElementById("eloadForm");
  const gcashForm = document.getElementById("gcashForm");
  const eloadMobileInput = document.getElementById("eloadMobileNumber");
  const gcashMobileInput = document.getElementById("gcashMobileNumber");
  const eloadNetworkGrid = document.getElementById("eloadNetworkGrid");
  const eloadPromoSelect = document.getElementById("eloadPromoSelect");
  const eloadRegularAmount = document.getElementById("eloadRegularAmount");
  const eloadNetworkValue = document.getElementById("eloadNetworkValue");
  const eloadLoadValue = document.getElementById("eloadLoadValue");
  const eloadAmountValue = document.getElementById("eloadAmountValue");
  const loadTypeRadios = document.querySelectorAll("input[name='loadType']");
  const promoGroup = document.getElementById("promoGroup");
  const regularGroup = document.getElementById("regularGroup");
  const failRequestModal = document.getElementById("failRequestModal");
  const failRequestForm = document.getElementById("failRequestForm");
  const failRequestCodeText = document.getElementById("failRequestCodeText");
  const failedReasonInput = document.getElementById("failedReasonInput");

  let selectedNetwork = "";
  const salesCartStorageKey = "sales-cart-state";
  const salesCartOpenStorageKey = "sales-cart-open-on-load";

  function onlyDigits(v) { return String(v || "").replace(/\D/g, "").slice(0, 11); }

  function formatMobile(v) {
    const d = onlyDigits(v);
    return [d.slice(0,4), d.slice(4,7), d.slice(7,11)].filter(Boolean).join(" ");
  }

  function parseAmount(v) {
    const m = String(v || "").match(/(\d+)/g);
    return m ? Number(m[m.length-1]) : 0;
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function getSelectedPromo() {
    if (!selectedNetwork) return null;
    return (networkPromos[selectedNetwork] || []).find((promo) => promo.name === eloadPromoSelect.value) || null;
  }

  function copyToClipboard(text, btn) {
    const rawNumber = String(text || "").replace(/\D/g, "");
    const icon = btn.querySelector("i");
    const originalClass = icon.className;
    const originalTitle = btn.title;

    function showSuccess() {
      icon.className = "bi bi-check-lg text-success";
      btn.title = "Copied!";
      setTimeout(() => {
        icon.className = originalClass;
        btn.title = originalTitle;
      }, 2000);
    }

    if (!navigator.clipboard) {
      const textArea = document.createElement("textarea");
      textArea.value = rawNumber;
      textArea.style.position = "fixed";
      textArea.style.left = "-9999px";
      textArea.style.top = "0";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        if (document.execCommand('copy')) showSuccess();
      } catch (err) {
        console.error("Fallback copy failed", err);
      }
      document.body.removeChild(textArea);
      return;
    }

    navigator.clipboard.writeText(rawNumber).then(showSuccess, (err) => {
      console.error("Async copy failed", err);
    });
  }

  function renderNetworks() {
    eloadNetworkGrid.innerHTML = Object.keys(networkPromos).map(net => `
      <div class="col-4 col-md-2">
        <button type="button" class="btn w-100 py-2 border rounded-3 network-btn ${selectedNetwork === net ? 'btn-primary border-primary' : 'btn-white'}" data-network="${net}">
          <div class="fw-bold small">${net}</div>
        </button>
      </div>
    `).join("");
  }

  function updateEloadValues() {
    const type = document.querySelector("input[name='loadType']:checked").value;
    let val = "";
    let amt = 0;

    if (type === "promo") {
      val = eloadPromoSelect.value;
      amt = Number(getSelectedPromo()?.price || parseAmount(val));
    } else {
      amt = Number(eloadRegularAmount.value || 0);
      val = amt ? `Regular ${amt}` : "";
    }

    eloadNetworkValue.value = selectedNetwork;
    eloadLoadValue.value = val;
    eloadAmountValue.value = amt;
  }

  // Event Listeners
  eloadMobileInput.addEventListener("input", (e) => e.target.value = formatMobile(e.target.value));
  gcashMobileInput.addEventListener("input", (e) => e.target.value = formatMobile(e.target.value));

  eloadNetworkGrid.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-network]");
    if (!btn) return;
    selectedNetwork = btn.dataset.network;
    renderNetworks();
    
    eloadPromoSelect.disabled = false;
    eloadPromoSelect.innerHTML = `<option value="">Select Promo</option>` + (networkPromos[selectedNetwork] || []).map((p) => `<option value="${escapeHtml(p.name)}">${escapeHtml(p.name)} - ${peso.format(Number(p.price || 0))}</option>`).join("");
    updateEloadValues();
  });

  loadTypeRadios.forEach(r => r.addEventListener("change", (e) => {
    promoGroup.classList.toggle("d-none", e.target.value !== "promo");
    regularGroup.classList.toggle("d-none", e.target.value !== "regular");
    updateEloadValues();
  }));

  eloadPromoSelect.addEventListener("change", updateEloadValues);
  eloadRegularAmount.addEventListener("input", updateEloadValues);

  document.getElementById("eloadAddToCartButton").addEventListener("click", () => {
    try {
      const num = onlyDigits(eloadMobileInput.value);
      if (num.length !== 11) throw new Error("Invalid mobile number.");
      if (!selectedNetwork) throw new Error("Select a network.");
      if (!eloadLoadValue.value) throw new Error("Select a load option.");

      const item = {
        id: `eload-${Date.now()}`,
        type: "eload",
        name: `${selectedNetwork} ${eloadLoadValue.value}`,
        mobileNumber: formatMobile(num),
        network: selectedNetwork,
        loadType: document.querySelector("input[name='loadType']:checked").value,
        loadValue: eloadLoadValue.value,
        price: Number(eloadAmountValue.value),
        quantity: 1
      };

      const cart = JSON.parse(localStorage.getItem(salesCartStorageKey) || "[]");
      cart.push(item);
      localStorage.setItem(salesCartStorageKey, JSON.stringify(cart));
      localStorage.setItem(salesCartOpenStorageKey, "true");
      window.location.href = "/sales";
    } catch (err) {
      alert(err.message);
    }
  });

  if (failRequestModal) {
    failRequestModal.addEventListener("show.bs.modal", (e) => {
      const btn = e.relatedTarget;
      failRequestForm.action = `/eload/requests/${btn.dataset.requestId}/fail`;
      failRequestCodeText.textContent = btn.dataset.requestCode;
      failedReasonInput.value = "";
    });
  }

  // Init
  renderNetworks();
  if (window.location.hash === "#view-set") {
    const setTab = document.getElementById("nav-set-tab");
    if (setTab && window.bootstrap) bootstrap.Tab.getOrCreateInstance(setTab).show();
  }
</script></body>
</html>
